[Unit]
Description=PAI First-Boot Model Setup
After=ollama.service network-online.target
Wants=ollama.service network-online.target
ConditionPathExists=!/var/lib/pai/.setup-done

[Service]
Type=oneshot
ExecStart=/usr/local/bin/pai-setup
ExecStartPost=/bin/bash -c 'mkdir -p /var/lib/pai && touch /var/lib/pai/.setup-done'
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
