---
import AppStandalone from '../../layouts/AppStandalone.astro'
import Head from '../../components/Head.astro'
import release from '../../data/release.json'

const noRelease = !release.sha256 || release.sha256 === 'not-yet-released'
const shortSha = noRelease ? '' : release.sha256.slice(0, 16) + '…'
const hasGpg = Boolean(release.gpgFingerprint?.trim())
---

<!doctype html>
<html lang="en">
  <head>
    <Head
      title="Verify — PAI"
      description="Verify the integrity of a downloaded PAI ISO against its published SHA-256 checksum — fully client-side, no upload."
      ogImage="/og/verify.png"
    />
    <link rel="icon" type="image/svg+xml" href="/icons/verify.svg" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html, body {
        height: 100%;
        background: #0f0f1a;
        color: #e0e0e0;
        font-family: system-ui, sans-serif;
        font-size: 13px;
      }

      body { display: flex; flex-direction: column; overflow: hidden; }

      #app-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
      }

      .verify-app {
        flex: 1;
        overflow-y: auto;
        padding: 16px 18px;
        scrollbar-width: thin;
        scrollbar-color: #2a2a3e transparent;
      }

      /* ── App header ─────────────────────────────────────────────────────────── */
      .app-title {
        font-size: 15px;
        font-weight: 700;
        color: #e0e0e0;
        margin-bottom: 4px;
      }

      .app-subtitle {
        font-size: 11px;
        color: #666;
        margin-bottom: 18px;
      }

      /* ── Steps ──────────────────────────────────────────────────────────────── */
      .step {
        border: 1px solid #2a2a3e;
        border-radius: 8px;
        margin-bottom: 14px;
        overflow: hidden;
      }

      .step-header {
        background: #1a1a2e;
        padding: 10px 14px;
        display: flex;
        align-items: center;
        gap: 10px;
        border-bottom: 1px solid #2a2a3e;
      }

      .step-num {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: #2a2a4e;
        border: 2px solid #7aa2f7;
        color: #7aa2f7;
        font-size: 11px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }

      .step-num.done {
        background: #4ade80;
        border-color: #4ade80;
        color: #0f1a0f;
      }

      .step-title { font-weight: 600; font-size: 13px; }

      .step-body { padding: 14px 16px; }

      /* ── Drop zone ──────────────────────────────────────────────────────────── */
      .drop-zone {
        border: 2px dashed #2a2a3e;
        border-radius: 8px;
        padding: 28px 16px;
        text-align: center;
        cursor: pointer;
        transition: border-color 0.15s, background 0.15s;
        margin-bottom: 14px;
        background: #12121f;
      }

      .drop-zone:hover,
      .drop-zone.over { border-color: #7aa2f7; background: #0f1a2e; }

      .drop-zone input[type="file"] {
        display: none;
      }

      .drop-icon { font-size: 28px; margin-bottom: 8px; }
      .drop-text { color: #888; font-size: 12px; }
      .drop-text strong { color: #7aa2f7; }

      /* ── Progress ───────────────────────────────────────────────────────────── */
      .progress-wrap { margin-bottom: 14px; }

      .progress-bar {
        background: #2a2a3e;
        border-radius: 4px;
        height: 8px;
        overflow: hidden;
      }

      .progress-fill {
        background: #7aa2f7;
        height: 100%;
        width: 0;
        transition: width 0.2s;
        border-radius: 4px;
      }

      .progress-label { color: #888; font-size: 11px; margin-top: 5px; }

      /* ── Hash result ─────────────────────────────────────────────────────────── */
      .hash-result { display: none; }

      .hash-row {
        display: grid;
        grid-template-columns: 72px 1fr;
        gap: 8px;
        align-items: start;
        margin-bottom: 8px;
      }

      .hash-label {
        font-size: 11px;
        color: #888;
        padding-top: 2px;
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }

      .hash-value {
        font-family: ui-monospace, monospace;
        font-size: 11px;
        word-break: break-all;
        line-height: 1.5;
        color: #c0d0f0;
      }

      .hash-status {
        margin-top: 10px;
        padding: 10px 14px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 13px;
        font-weight: 600;
      }

      .hash-status.match {
        background: #0a1f0a;
        border: 1px solid #1e5a1e;
        color: #4ade80;
      }

      .hash-status.mismatch {
        background: #200a0a;
        border: 1px solid #5a1e1e;
        color: #f87171;
      }

      .status-icon { font-size: 18px; flex-shrink: 0; }

      /* ── Privacy note ────────────────────────────────────────────────────────── */
      .privacy-note {
        background: #12121f;
        border: 1px solid #2a2a3e;
        border-radius: 5px;
        color: #666;
        font-size: 11px;
        padding: 6px 10px;
        margin-bottom: 12px;
        display: flex;
        gap: 6px;
        align-items: flex-start;
      }

      /* ── Code block ──────────────────────────────────────────────────────────── */
      .code-wrap {
        background: #12121f;
        border: 1px solid #2a2a3e;
        border-radius: 5px;
        margin: 8px 0;
        position: relative;
      }

      .code-wrap pre {
        font-family: ui-monospace, monospace;
        font-size: 11.5px;
        padding: 10px 40px 10px 12px;
        overflow-x: auto;
        line-height: 1.6;
        color: #c0d0f0;
        white-space: pre;
      }

      .copy-btn {
        position: absolute;
        top: 6px;
        right: 6px;
        background: #1a1a2e;
        border: 1px solid #2a2a3e;
        border-radius: 4px;
        color: #888;
        cursor: pointer;
        font-size: 10px;
        padding: 3px 7px;
        font-family: inherit;
      }
      .copy-btn:hover { color: #7aa2f7; border-color: #7aa2f7; }
      .copy-btn.copied { color: #4ade80; border-color: #4ade80; }

      /* ── Links ───────────────────────────────────────────────────────────────── */
      a { color: #7aa2f7; }

      /* ── Collapsible ──────────────────────────────────────────────────────────── */
      details { margin-top: 12px; }
      summary {
        cursor: pointer;
        color: #7aa2f7;
        font-size: 12px;
        list-style: none;
        display: flex;
        align-items: center;
        gap: 6px;
      }
      summary::-webkit-details-marker { display: none; }
      summary::before { content: '▶'; font-size: 9px; transition: transform 0.15s; }
      details[open] summary::before { transform: rotate(90deg); }

      .details-body {
        color: #888;
        font-size: 12px;
        line-height: 1.7;
        padding: 10px 0 4px 20px;
      }

      .notice {
        background: rgba(251, 191, 36, 0.08);
        border: 1px solid rgba(251, 191, 36, 0.3);
        border-radius: 6px;
        padding: 10px 14px;
        font-size: 12px;
        color: #c0c0d0;
        line-height: 1.6;
      }

      .fingerprint {
        font-family: ui-monospace, monospace;
        font-size: 11px;
        color: #7aa2f7;
        word-break: break-all;
        background: #12121f;
        border: 1px solid #2a2a3e;
        border-radius: 4px;
        padding: 4px 8px;
        display: inline-block;
        margin: 4px 0;
      }

      .transparency-link {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 0;
        border-bottom: 1px solid #1a1a2e;
        font-size: 12px;
        color: #c0c0d0;
        text-decoration: none;
      }
      .transparency-link:last-child { border-bottom: none; }
      .transparency-link:hover { color: #7aa2f7; }
      .tl-icon { font-size: 16px; width: 24px; text-align: center; }
    </style>
  </head>
  <body>
    <AppStandalone appId="verify" />
    <main id="app-content">
      <div class="verify-app">

        <div class="app-title">Verify PAI image</div>
        <div class="app-subtitle">
          Three steps: hash the file, check the signature, trace the build. All client-side — nothing is uploaded.
        </div>

        {noRelease ? (
          <div style="margin-top:32px;text-align:center;color:#888;font-size:13px;line-height:1.7;">
            <div style="font-size:28px;margin-bottom:12px;">🔜</div>
            <p style="color:#c0c0d0;font-weight:600;margin-bottom:6px;">No release published yet — check back soon.</p>
            <p>The first PAI image is being prepared. Once published,<br>this page will show the SHA256 checksum and GPG signature.</p>
            <p style="margin-top:12px;"><a href="https://github.com/nirholas/pai/releases" target="_blank" rel="noopener noreferrer">GitHub releases</a></p>
          </div>
        ) : (
          <Fragment>

        <!-- ── Step 1: File hash ──────────────────────────────────────────────── -->
        <section class="step">
          <div class="step-header">
            <div class="step-num" id="step1-num">1</div>
            <span class="step-title">File — SHA256 checksum</span>
          </div>
          <div class="step-body">

            <div class="privacy-note" role="note">
              <span>🔒</span>
              <span>Computed entirely in your browser. The file never leaves your device.</span>
            </div>

            <label class="drop-zone" id="drop-zone" for="file-input">
              <input type="file" id="file-input" accept=".iso,application/octet-stream" />
              <div class="drop-icon">⬇</div>
              <div class="drop-text">
                <strong>Drop your .iso here</strong> or click to select<br>
                Works with files of any size, including 6+ GB images
              </div>
            </label>

            <div class="progress-wrap" id="hash-progress" style="display:none" role="status" aria-live="polite">
              <div class="progress-bar"><div class="progress-fill" id="hash-fill"></div></div>
              <div class="progress-label" id="hash-label">Computing SHA256…</div>
            </div>

            <div class="hash-result" id="hash-result">
              <div class="hash-row">
                <span class="hash-label">Computed</span>
                <span class="hash-value" id="computed-hash"></span>
              </div>
              <div class="hash-row">
                <span class="hash-label">Expected</span>
                <span class="hash-value" id="expected-hash">{release.sha256}</span>
              </div>
              <div class="hash-status" id="hash-status" role="alert" aria-live="assertive"></div>
            </div>
          </div>
        </section>

        <!-- ── Step 2: GPG signature ──────────────────────────────────────────── -->
        <section class="step">
          <div class="step-header">
            <div class="step-num" id="step2-num">2</div>
            <span class="step-title">Signature — GPG verification</span>
          </div>
          <div class="step-body">
            {hasGpg ? (
              <Fragment>
                <p style="color:#888;font-size:12px;line-height:1.6;margin-bottom:12px">
                  GPG verification requires native tooling — we intentionally don't run it in the
                  browser to avoid a complex JS cryptography dependency. Run these commands in your
                  terminal.
                </p>

                <p style="font-size:12px;color:#c0c0d0;margin-bottom:6px">1. Import the signing key:</p>
                <div class="code-wrap">
                  <pre>gpg --recv-keys {release.gpgFingerprint.replace(/\s/g, '')}</pre>
                  <button class="copy-btn" data-copy={`gpg --recv-keys ${release.gpgFingerprint.replace(/\s/g, '')}`}>copy</button>
                </div>

                <p style="font-size:12px;color:#c0c0d0;margin:10px 0 6px">2. Verify:</p>
                <div class="code-wrap">
                  <pre>gpg --verify {release.isoName}.asc {release.isoName}</pre>
                  <button class="copy-btn" data-copy={`gpg --verify ${release.isoName}.asc ${release.isoName}`}>copy</button>
                </div>

                <p style="font-size:11px;color:#888;margin-top:8px">
                  Expected: <em>Good signature from "PAI Release Signing Key"</em><br>
                  Key fingerprint: <span class="fingerprint">{release.gpgFingerprint}</span>
                </p>
              </Fragment>
            ) : (
              <div class="notice">
                GPG signing is in progress — signature files will be available with the
                first stable release.
              </div>
            )}

            {hasGpg && (
              <p style="font-size:12px;color:#888;margin-top:10px">
                <a href={release.signatureUrl} target="_blank" rel="noopener noreferrer">Download signature file (.asc)</a>
              </p>
            )}
          </div>
        </section>

        <!-- ── Step 3: Transparency ───────────────────────────────────────────── -->
        <section class="step">
          <div class="step-header">
            <div class="step-num">3</div>
            <span class="step-title">Transparency — build provenance</span>
          </div>
          <div class="step-body">

            <a class="transparency-link" href={release.releaseUrl} target="_blank" rel="noreferrer">
              <span class="tl-icon">🏷</span>
              <span>GitHub release — {release.isoName} v{release.version}</span>
            </a>
            <a class="transparency-link" href={release.buildWorkflowUrl} target="_blank" rel="noreferrer">
              <span class="tl-icon">⚙️</span>
              <span>CI/CD build workflow run</span>
            </a>

            <details>
              <summary>Why should I trust this?</summary>
              <div class="details-body">
                <p>PAI images are built by a public CI/CD pipeline on GitHub Actions. You can:</p>
                <ul style="padding-left:16px;margin-top:6px;line-height:2">
                  <li>Inspect every line of the <a href="https://github.com/pai-os/pai" target="_blank" rel="noopener noreferrer">build scripts</a></li>
                  <li>Re-run the workflow yourself on your own GitHub account</li>
                  <li>Compare the SHA256 hash of your locally-built image to the released one</li>
                  <li>Verify the GPG signature against a key whose fingerprint is published in the repo</li>
                </ul>
                <p style="margin-top:10px">
                  If the SHA256 in Step 1 matches and the GPG signature in Step 2 is valid,
                  you have cryptographic proof the file you downloaded is identical to what
                  the build pipeline produced — byte for byte.
                </p>
              </div>
            </details>

          </div>
        </section>

          </Fragment>
        )}

      <script type="application/json" id="release-data" set:text={JSON.stringify(release)}></script>
      </div>
    </main>
  </body>
</html>

<script>
  import { bridge } from '../../apps/_bridge.js'
  import { hashFile } from '../../apps/verify/hash.js'

  const release = JSON.parse(document.getElementById('release-data')!.textContent!)

  bridge.ready()

  const dropZone = document.getElementById('drop-zone')
  const fileInput = document.getElementById('file-input')
  const progressWrap = document.getElementById('hash-progress')
  const fill = document.getElementById('hash-fill')
  const label = document.getElementById('hash-label')
  const resultEl = document.getElementById('hash-result')
  const computedEl = document.getElementById('computed-hash')
  const statusEl = document.getElementById('hash-status')
  const step1Num = document.getElementById('step1-num')

  // Drag-and-drop highlight
  dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('over') })
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('over'))
  dropZone.addEventListener('drop', e => {
    e.preventDefault()
    dropZone.classList.remove('over')
    const file = e.dataTransfer?.files?.[0]
    if (file) processFile(file)
  })

  fileInput.addEventListener('change', () => {
    const file = fileInput.files?.[0]
    if (file) processFile(file)
  })

  async function processFile(file) {
    // Show progress
    dropZone.style.display = 'none'
    progressWrap.style.display = 'block'
    resultEl.style.display = 'none'

    try {
      const hash = await hashFile(file, pct => {
        fill.style.width = (pct * 100).toFixed(1) + '%'
        label.textContent = `Computing SHA256… ${(pct * 100).toFixed(0)}%  (${(file.size / 1e9).toFixed(1)} GB file)`
      })

      // Show result
      fill.style.width = '100%'
      label.textContent = 'Done.'
      resultEl.style.display = 'block'
      computedEl.textContent = hash

      const expected = release.sha256.toLowerCase()
      const match = hash === expected

      if (match) {
        statusEl.className = 'hash-status match'
        statusEl.innerHTML = '<span class="status-icon" aria-hidden="true">✓</span><span>Match — this file is genuine</span>'
        step1Num.classList.add('done')
        step1Num.textContent = '✓'
      } else {
        statusEl.className = 'hash-status mismatch'
        statusEl.innerHTML =
          '<span class="status-icon" aria-hidden="true">✗</span>' +
          '<span>Mismatch — do not flash this file. Download it again or check the expected hash on the release page.</span>'
      }
    } catch (err) {
      label.textContent = `Error: ${err.message}`
      fill.style.background = '#f87171'
    }
  }

  // Copy buttons
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      await navigator.clipboard.writeText(btn.dataset.copy).catch(() => {})
      btn.textContent = 'copied!'
      btn.classList.add('copied')
      setTimeout(() => { btn.textContent = 'copy'; btn.classList.remove('copied') }, 1800)
    })
  })
</script>
