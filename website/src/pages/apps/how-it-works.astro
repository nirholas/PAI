---
import ContentApp from '../../layouts/ContentApp.astro'

const sections = [
  { id: 'leave-no-trace', label: 'Leave no trace on the computer' },
  { id: 'amnesia', label: 'Amnesia' },
  { id: 'persistence', label: 'Encrypted persistence' },
  { id: 'private-ai', label: 'Private AI, offline' },
  { id: 'hardened-network', label: 'Hardened networking' },
  { id: 'digital-toolbox', label: 'Digital toolbox' },
  { id: 'free-software', label: 'Software for freedom' },
  { id: 'top-security-free', label: 'Top security for free' },
