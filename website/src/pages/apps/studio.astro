---
import AppStandalone from '../../layouts/AppStandalone.astro'
import Head from '../../components/Head.astro'
import { APPS } from '../../shell/apps.js'
import '../../styles/global.css'
import '../../shell/apps.css'
import '../../apps/studio/studio.css'

const app = APPS.studio
---

<!doctype html>
<html lang="en">
  <head>
    <Head
      title={`${app.title} — PAI`}
      description={app.description}
      ogImage={app.ogImage}
    />
    <link rel="icon" type="image/svg+xml" href="/icons/studio.svg" />
  </head>
  <body>
    <a href="#app-content" class="skip-link">Skip to app content</a>
    <AppStandalone appId="studio" />
    <main id="app-content" class="app-content" data-app-id="studio"></main>

    <style>
      body {
        display: flex;
        flex-direction: column;
        min-height: 100dvh;
        background: var(--bg, #0f0f1a);
      }
      .app-content {
        flex: 1;
        min-height: 0;
        overflow: hidden;
        display: flex;
        flex-direction: column;
      }
      .skip-link {
        position: absolute;
        top: -100%;
        left: var(--s-2);
        background: var(--pai-blue);
        color: #0f0f1a;
        padding: var(--s-1) var(--s-3);
        border-radius: var(--r-icon);
        font-weight: 600;
        font-size: 0.875rem;
        z-index: 9999;
        text-decoration: none;
      }
      .skip-link:focus { top: var(--s-2); }
    </style>

    <script>
      import { bridge } from '../../apps/_bridge.js'
      import { StudioApp } from '../../apps/studio/studio.ts'

      bridge.ready()
      const container = document.getElementById('app-content')!
      new StudioApp(container)
    </script>
  </body>
</html>
