---
import AppStandalone from '../../layouts/AppStandalone.astro'
import Head from '../../components/Head.astro'
---

<!doctype html>
<html lang="en">
  <head>
    <Head
      title="Companion — PAI"
      description="A friendly local companion that answers questions about PAI and opens relevant apps — fully offline, no LLM, no network."
      ogImage="/og/companion.png"
    />
    <link rel="icon" type="image/svg+xml" href="/icons/companion.svg" />
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html,
      body {
        height: 100%;
        font-family:
          ui-sans-serif, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
          Helvetica, Arial, sans-serif;
        background: #0f0f1a;
        color: #e0e0e0;
      }
      body {
        display: flex;
        flex-direction: column;
        overflow: hidden;
      }
      #app-root {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
      }
      .cmp-head {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 16px 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        background: linear-gradient(
          180deg,
          rgba(159, 122, 234, 0.12),
          rgba(244, 114, 182, 0.06)
        );
      }
      .cmp-name {
        font-size: 1rem;
        font-weight: 600;
      }
      .cmp-sub {
        font-size: 0.75rem;
        color: #888;
      }
      .cmp-log {
        flex: 1;
        overflow: auto;
        padding: 16px 20px;
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .bubble {
        max-width: 80%;
        padding: 10px 14px;
        border-radius: 12px;
        font-size: 0.875rem;
        line-height: 1.5;
      }
      .bubble--cmp {
        background: #1a1a2e;
        border: 1px solid #2a2a3e;
        color: #e0e0e0;
        align-self: flex-start;
        border-bottom-left-radius: 4px;
      }
      .bubble--me {
        background: #7aa2f7;
        color: #0f0f1a;
        align-self: flex-end;
        border-bottom-right-radius: 4px;
      }
      .chips {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        align-self: flex-start;
        max-width: 100%;
      }
      .chip {
        appearance: none;
        border: 1px solid #2a2a3e;
        background: #0f0f1a;
        color: #7aa2f7;
        border-radius: 999px;
        padding: 6px 12px;
        font-size: 0.75rem;
        font-family: inherit;
        cursor: pointer;
        transition: background 120ms;
      }
      .chip:hover {
        background: rgba(122, 162, 247, 0.12);
      }
      .cmp-foot {
        display: flex;
        gap: 8px;
        padding: 12px 16px;
        border-top: 1px solid rgba(255, 255, 255, 0.06);
        background: #0f0f1a;
      }
      .cmp-input {
        flex: 1;
        padding: 10px 12px;
        border-radius: 6px;
        border: 1px solid #2a2a3e;
        background: #1a1a2e;
        color: #e0e0e0;
        font-family: inherit;
        font-size: 0.875rem;
      }
      .cmp-input:focus {
        outline: 2px solid #7aa2f7;
        outline-offset: 1px;
      }
      .cmp-send {
        appearance: none;
        background: #7aa2f7;
        color: #0f0f1a;
        border: 1px solid #7aa2f7;
        border-radius: 6px;
        padding: 10px 16px;
        font-size: 0.875rem;
        font-weight: 600;
        cursor: pointer;
      }
      .cmp-send:hover {
        background: #8cb3ff;
      }
    </style>
  </head>
  <body>
    <AppStandalone appId="companion" />
    <div id="app-root">
      <header class="cmp-head">
        <svg
          class="cmp-avatar cmp-happy"
          id="cmp-avatar"
          viewBox="0 0 96 96"
          aria-hidden="true"
        >
          <defs>
            <radialGradient id="cmp-grad" cx="50%" cy="40%" r="55%">
              <stop offset="0" stop-color="#f472b6" />
              <stop offset="1" stop-color="#9f7aea" />
            </radialGradient>
          </defs>
          <circle cx="48" cy="48" r="42" fill="url(#cmp-grad)" />
          <ellipse
            class="cmp-eye cmp-eye--left"
            cx="36"
            cy="42"
            rx="4"
            ry="5"
            fill="#0f0f1a"
          />
          <ellipse
            class="cmp-eye cmp-eye--right"
            cx="60"
            cy="42"
            rx="4"
            ry="5"
            fill="#0f0f1a"
          />
          <path
            class="cmp-mouth"
            d="M 32 58 Q 48 72 64 58"
            stroke="#0f0f1a"
            stroke-width="3"
            stroke-linecap="round"
            fill="none"
          />
          <circle cx="26" cy="54" r="3" fill="#ffffff" opacity="0.35" />
          <circle cx="70" cy="54" r="3" fill="#ffffff" opacity="0.35" />
        </svg>
        <div>
          <div class="cmp-name">PAI Companion</div>
          <div class="cmp-sub">Runs locally — no LLM, no network</div>
        </div>
      </header>
      <div class="cmp-log" id="cmp-log" role="log" aria-live="polite"></div>
      <form class="cmp-foot" id="cmp-form">
        <input
          class="cmp-input"
          id="cmp-input"
          type="text"
          placeholder="Ask about PAI…"
          autocomplete="off"
          aria-label="Ask the PAI companion"
        />
        <button class="cmp-send" type="submit">Send</button>
      </form>
    </div>

    <script>
      import '../../apps/companion/avatar.css'
      import { bridge } from '../../apps/_bridge.js'
      import { brain, type Reply, type Chip } from '../../apps/companion/brain.ts'

      bridge.ready()

      const log = document.getElementById('cmp-log')!
      const form = document.getElementById('cmp-form') as HTMLFormElement
      const input = document.getElementById('cmp-input') as HTMLInputElement
      const avatar = document.getElementById('cmp-avatar')!

      function setMood(mood?: Reply['mood']): void {
        const m = mood ?? 'happy'
        avatar.classList.remove(
          'cmp-happy',
          'cmp-proud',
          'cmp-curious',
          'cmp-thinking',
        )
        avatar.classList.add(`cmp-${m}`)
      }

      function escapeText(s: string): string {
        const d = document.createElement('div')
        d.textContent = s
        return d.innerHTML
      }

      function pushBubble(text: string, who: 'cmp' | 'me'): void {
        const b = document.createElement('div')
        b.className = `bubble bubble--${who}`
        b.textContent = text
        log.appendChild(b)
        log.scrollTop = log.scrollHeight
      }

      function pushChips(chips: Chip[]): void {
        if (!chips.length) return
        const row = document.createElement('div')
        row.className = 'chips'
        chips.forEach((c) => {
          const btn = document.createElement('button')
          btn.className = 'chip'
          btn.type = 'button'
          btn.textContent = c.label
          btn.addEventListener('click', () => {
            if (c.appId) {
              bridge.openApp(c.appId)
              pushBubble(`Opening ${c.appId}…`, 'me')
            } else if (c.query) {
              input.value = c.query
              submit()
            }
          })
          row.appendChild(btn)
        })
        log.appendChild(row)
        log.scrollTop = log.scrollHeight
      }

      function respond(reply: Reply): void {
        pushBubble(reply.text, 'cmp')
        setMood(reply.mood)
        if (reply.chips) pushChips(reply.chips)
      }

      function submit(): void {
        const msg = input.value.trim()
        if (!msg) return
        pushBubble(msg, 'me')
        input.value = ''
        setMood('thinking')
        setTimeout(() => respond(brain.ask(msg)), 180)
      }

      form.addEventListener('submit', (e) => {
        e.preventDefault()
        submit()
      })

      respond(brain.greet())
      input.focus()
    </script>
  </body>
</html>
