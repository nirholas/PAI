---
// WM test harness — not linked from nav.
// Open http://localhost:4321/_wm-test to manually verify WM behavior.
import Shell from '../layouts/Shell.astro'
import '../shell/windows.css'
---

<Shell
  title="WM Test — PAI"
  description="Window manager test harness for manual verification of drag, resize, focus, keyboard, snap."
>
  <div slot="desktop" class="wm-test-desktop">
    <div class="wm-test-hint" aria-hidden="true">
      WM test — click buttons to open windows
    </div>
  </div>

  <div slot="windows" class="wm-test-controls" role="toolbar" aria-label="Test controls">
    <button id="btn-about"    type="button">Open About</button>
    <button id="btn-docs"     type="button">Open Docs</button>
    <button id="btn-flash"    type="button">Open Flash</button>
    <button id="btn-close-all" type="button">Close All</button>
    <div class="wm-test-status" id="wm-status" role="status" aria-live="polite"></div>
  </div>
</Shell>

<script>
  import { wm } from '../shell/wm.js'

  function status(msg) {
    const el = document.getElementById('wm-status')
    if (el) el.textContent = msg
  }

  wm.on('open',     ({ id, appId }) => status(`Opened ${appId} → ${id}`))
  wm.on('close',    ({ id, appId }) => status(`Closed ${appId} (${id})`))
  wm.on('focus',    ({ id, appId }) => status(`Focused ${appId} (${id})`))
  wm.on('minimize', ({ id, minimized }) => status(`${minimized ? 'Minimized' : 'Restored'} ${id}`))

  document.getElementById('btn-about')?.addEventListener('click', () => {
    wm.open('about', { title: 'About PAI' })
  })

  document.getElementById('btn-docs')?.addEventListener('click', () => {
    wm.open('docs', { title: 'Docs' })
  })

  document.getElementById('btn-flash')?.addEventListener('click', () => {
    wm.open('flash', { title: 'Flash USB' })
  })

  document.getElementById('btn-close-all')?.addEventListener('click', () => {
    wm.list().forEach(w => wm.close(w.id))
    status('All windows closed')
  })

  // Keyboard hint overlay
  const hint = document.createElement('div')
  hint.className = 'wm-test-kbd-hint'
  hint.setAttribute('role', 'note')
  hint.innerHTML = `
    <strong>Keyboard:</strong>
    Alt+Tab (cycle) · Alt+F4 / Ctrl+W (close) ·
    Ctrl+W (close) · Super+↑ (max) · Super+↓ (restore) ·
    Super+← (tile left) · Super+→ (tile right) ·
    Esc (close focused) · Tab (cycle titlebar controls)
  `
  document.querySelector('.wm-test-desktop')?.appendChild(hint)
</script>

<style>
  .wm-test-desktop {
    position: absolute;
    inset: 0;
    background: var(--bg);
    background-image:
      radial-gradient(circle at 20% 30%, rgba(122, 162, 247, 0.06) 0%, transparent 50%),
      radial-gradient(circle at 80% 70%, rgba(159, 122, 234, 0.06) 0%, transparent 50%);
  }

  .wm-test-hint {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-pixel);
    font-size: 11px;
    color: var(--fg-muted);
    letter-spacing: 0.05em;
    pointer-events: none;
    user-select: none;
  }

  .wm-test-controls {
    position: absolute;
    top: 12px;
    left: 12px;
    display: flex;
    gap: var(--s-2);
    align-items: center;
    flex-wrap: wrap;
    pointer-events: auto;
    z-index: 50;
  }

  .wm-test-controls button {
    background: var(--bg-chrome);
    color: var(--fg);
    border: 1px solid var(--border);
    border-radius: var(--r-icon);
    padding: 6px 14px;
    font-family: var(--font-pixel);
    font-size: 12px;
    cursor: pointer;
    transition: background 80ms ease;
  }

  .wm-test-controls button:hover {
    background: rgba(122, 162, 247, 0.15);
    border-color: var(--pai-blue);
  }

  .wm-test-controls button:focus-visible {
    outline: 2px solid var(--pai-blue);
    outline-offset: 2px;
  }

  .wm-test-status {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--pai-green);
    min-width: 220px;
    padding: 4px 8px;
  }

  .wm-test-kbd-hint {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(20, 20, 30, 0.9);
    border: 1px solid var(--border);
    border-radius: var(--r-icon);
    padding: 8px 16px;
    font-size: 11px;
    color: var(--fg-muted);
    font-family: var(--font-mono);
    white-space: nowrap;
    pointer-events: none;
  }

  .wm-test-kbd-hint strong {
    color: var(--fg);
  }
</style>
