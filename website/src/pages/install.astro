---
import '../styles/global.css'
import release from '../data/release.json'

const sizeFmt = (release.sizeMB / 1024).toFixed(1) + ' GB'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Install PAI</title>
    <meta
      name="description"
      content="Install PAI on a USB drive — one PowerShell command on Windows (flash.ps1), dd on macOS/Linux, Pi Imager for Raspberry Pi, or drag-and-drop with Ventoy."
    />
    <link rel="icon" href="/logo/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/logo/favicon-32.png" />
  </head>
  <body class="install-body">
    <a href="#install-main" class="skip-link">Skip to main content</a>

    <header class="install-topbar">
      <div class="install-container install-topbar__inner">
        <a class="install-brand" href="/" aria-label="PAI home">
          <span class="install-brand__logo" aria-hidden="true">◆</span>
          <span class="install-brand__name">PAI</span>
        </a>
        <nav class="install-nav" aria-label="Primary">
          <a href="/">Home</a>
          <a href="/apps/docs">Documentation</a>
          <a href="/install" aria-current="page" class="is-active">Install PAI</a>
          <a href="/apps/faq">Support</a>
          <a href="/apps/changelog">News</a>
        </nav>
      </div>
    </header>

    <main id="install-main" class="install-container install-main">
      <section class="install-hero">
        <div class="install-container">
          <h1>Install PAI</h1>
          <p class="install-hero__sub">
            Flash a USB, or try it instantly in a local VM — no commitment, no reboot.
          </p>
          <div class="install-hero__ctas">
            <a href="#try-it-now" class="install-btn install-btn--primary">Try it now in a VM</a>
            <a href="#pick-your-os" class="install-btn install-btn--secondary">Flash a USB drive</a>
          </div>
        </div>
      </section>

      <section id="try-it-now" class="install-section install-section--highlight">
        <h2>Try PAI in a VM — no USB, no reboot</h2>
        <p>
          The fastest way to see PAI. Runs in a local VM on your machine, boots in
          about 30 seconds, and cleans itself up when you close the window. Requires
          QEMU (the one-liner installs it if you don't have it).
        </p>

        <div class="install-try-tabs">
          <div class="install-try-tab" data-os="linux-mac">
            <h3>Linux / macOS</h3>
            <pre><code>curl -fsSL https://pai.direct/try | bash</code></pre>
          </div>
          <div class="install-try-tab" data-os="windows">
            <h3>Windows</h3>
            <pre><code>irm https://pai.direct/try.ps1 | iex</code></pre>
          </div>
        </div>

        <details class="install-try-details">
          <summary>What this does</summary>
          <ol>
            <li>Downloads the latest PAI ISO and verifies its SHA256.</li>
            <li>Installs QEMU if missing (prompts first).</li>
            <li>Boots PAI with hardware acceleration (KVM / HVF / WHPX) and 8 GB RAM.</li>
            <li>Forwards <code>localhost:8080</code> to Open WebUI inside the VM.</li>
            <li>Deletes the cached ISO on exit (pass <code>--keep</code> to preserve).</li>
          </ol>
        </details>

        <p class="install-try-next">
          Liked it? <a href="#pick-your-os">Flash a real USB</a> for full-speed offline use.
        </p>
      </section>

      <section id="flash-in-browser" class="install-section install-section--highlight">
        <h2>Flash PAI from your browser — no tools required</h2>
        <p>
          Download and verify the PAI ISO in your browser, then get a one-click command
          tailored to your OS. Firefox and Safari supported — with an experimental
          in-browser WebUSB write for Chrome and Edge users.
        </p>
        <a href="/flash-web" class="install-btn install-btn--primary">Start the browser installer →</a>
      </section>

      <div id="pick-your-os"></div>
      <p class="install-lede">
        Pick the platform you're installing PAI on — a USB drive for PCs and Macs,
        or a Raspberry Pi SD card via Raspberry Pi Imager.
      </p>

      <div class="os-grid" role="list">
        <a href="#windows" class="os-card" role="listitem" data-os="windows">
          <span class="os-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="44" height="44" fill="currentColor">
              <path d="M3 5.5 10.5 4.5v7H3zM11.5 4.3 21 3v8.5h-9.5zM3 12.5h7.5v7L3 18.5zM11.5 12.5H21V21l-9.5-1.3z"/>
            </svg>
          </span>
          <span class="os-card__label">Windows</span>
        </a>
        <a href="#macos" class="os-card" role="listitem" data-os="mac">
          <span class="os-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="44" height="44" fill="currentColor">
              <path d="M16.37 1.43c0 1.14-.44 2.23-1.17 3.02-.79.87-2.06 1.54-3.13 1.45-.13-1.12.43-2.29 1.17-3.03.83-.85 2.23-1.5 3.13-1.44zM20.5 17.1c-.56 1.24-.82 1.79-1.53 2.88-.99 1.53-2.39 3.44-4.13 3.45-1.54.02-1.94-.99-4.04-.98-2.1.02-2.54 1-4.08.98-1.74-.02-3.06-1.74-4.06-3.27C.05 16.12-.24 11.5 1.54 9.04c1.26-1.74 3.24-2.76 5.1-2.76 1.9 0 3.1 1.03 4.67 1.03 1.52 0 2.45-1.03 4.64-1.03 1.66 0 3.42.9 4.67 2.46-4.1 2.24-3.43 8.08.88 8.36z"/>
            </svg>
          </span>
          <span class="os-card__label">macOS</span>
        </a>
        <a href="#linux" class="os-card" role="listitem" data-os="linux">
          <span class="os-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="44" height="44" fill="currentColor">
              <path d="M12 2c-2.5 0-3.8 2.1-3.8 4.5 0 1 .2 1.9.6 2.7-.6.7-1.2 1.5-1.7 2.5-.9 1.8-1.4 3.8-2.3 4.9-.7.8-1.5 1.2-1.5 2.2 0 .6.4 1 .9 1.2.7.3 1.1.1 1.6.3.4.2.7.6 1.3.8.7.2 1.6 0 2.3-.4.3-.2.5-.4.7-.7h3.6c.2.3.5.5.8.7.7.4 1.6.6 2.3.4.6-.2.9-.6 1.3-.8.5-.2.9 0 1.6-.3.5-.2.9-.6.9-1.2 0-1-.8-1.4-1.5-2.2-.9-1.1-1.4-3.1-2.3-4.9-.5-1-1.1-1.8-1.7-2.5.4-.8.6-1.7.6-2.7 0-2.4-1.3-4.5-3.8-4.5zm-1.6 3.2c.4 0 .8.5.8 1.1s-.4 1-.8 1-.8-.4-.8-1 .4-1.1.8-1.1zm3.2 0c.4 0 .8.5.8 1.1s-.4 1-.8 1-.8-.4-.8-1 .4-1.1.8-1.1zM12 7.3c1.3 0 2.4.8 2.4 1.4 0 .3-.4.6-.9.9-.5.4-1 .7-1.5.7s-1-.3-1.5-.7c-.5-.3-.9-.6-.9-.9 0-.6 1.1-1.4 2.4-1.4z"/>
            </svg>
          </span>
          <span class="os-card__label">Linux</span>
        </a>
        <a href="#console" class="os-card" role="listitem" data-os="console">
          <span class="os-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="44" height="44" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="M6 9l3 3-3 3M12 15h5"/>
            </svg>
          </span>
          <span class="os-card__label">Console</span>
          <span class="os-card__sub">Linux/macOS using the<br/>command line and <code>dd</code></span>
        </a>
        <a href="#raspberry-pi" class="os-card" role="listitem" data-os="raspberry-pi">
          <span class="os-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="44" height="44" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="7" cy="8" r="2"/>
              <circle cx="17" cy="8" r="2"/>
              <path d="M5 10c-1 2-1 4 0 6h14c1-2 1-4 0-6"/>
              <path d="M9 16v3M15 16v3"/>
            </svg>
          </span>
          <span class="os-card__label">Raspberry Pi</span>
          <span class="os-card__sub">Pi 5, Pi 4, Pi 400,<br/>Pi Zero 2 W</span>
        </a>
        <a href="#ventoy" class="os-card" role="listitem" data-os="ventoy">
          <span class="os-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="44" height="44" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="6" y="3" width="12" height="18" rx="2"/>
              <path d="M9 7h6M9 11h6M9 15h6"/>
            </svg>
          </span>
          <span class="os-card__label">Ventoy (any OS)</span>
          <span class="os-card__sub">Multi-boot USB,<br/>no wipe needed</span>
        </a>
      </div>

      <p class="install-download">
        <a href={release.downloadUrl} download>
          Download PAI only (for USB sticks)
        </a>
      </p>

      <p class="install-version">
        Latest version: <a href={release.releaseUrl}>PAI {release.version} from {release.buildDate}</a>
        <span class="install-size"> · {sizeFmt}</span>
      </p>

      <aside class="install-callout">
        <div class="install-callout__icon" aria-hidden="true">↻</div>
        <div>
          <p>
            Already running PAI on a USB stick? You can clone it to a second stick
            without re-downloading the image:
          </p>
          <ul>
            <li><a href="https://docs.pai.direct/clone-usb" target="_blank" rel="noopener">Install by cloning from another PAI USB</a></li>
          </ul>
        </div>
      </aside>

      <aside class="install-callout install-callout--muted">
        <div class="install-callout__icon" aria-hidden="true">✕</div>
        <div>
          <p>
            <strong>PAI doesn't run on phones or tablets.</strong> Mobile hardware
            can't boot arbitrary Linux distributions — you need a PC, a Mac, or a
            supported Raspberry Pi.
          </p>
        </div>
      </aside>

      <p>
        <a href="/apps/hardware" class="install-link">System requirements and recommended USB sticks →</a>
      </p>

      <section id="windows" class="install-section">
        <h2>Windows</h2>
        <p>Open <strong>PowerShell as Administrator</strong> and run:</p>
        <pre><code>irm https://pai.direct/flash.ps1 | iex</code></pre>
        <p>
          The script downloads the latest PAI ISO, verifies its SHA256, lets you pick
          your USB drive, and writes it raw. Requires PowerShell 5.1 or newer. Reboot
          and press <kbd>F12</kbd> / <kbd>F2</kbd> / <kbd>DEL</kbd> at the BIOS splash
          to pick the USB drive.
        </p>
        <details>
          <summary>Prefer a graphical tool? Use Rufus (alternative)</summary>
          <ol>
            <li>Download the ISO using the button above.</li>
            <li>Install the <a href="https://rufus.ie" rel="noreferrer" target="_blank">Rufus graphical tool</a> (portable, no installer needed).</li>
            <li>Open the Rufus graphical tool, select your USB drive under <strong>Device</strong>.</li>
            <li>Click <strong>SELECT</strong>, choose the PAI ISO, then <strong>START</strong>. When prompted, choose <strong>Write in DD Image mode</strong>.</li>
            <li>Reboot and press <kbd>F12</kbd> / <kbd>F2</kbd> / <kbd>DEL</kbd> at the BIOS splash to pick the USB drive.</li>
          </ol>
        </details>
        <details>
          <summary>Verify the flasher before running (advanced)</summary>
          <pre><code>{`$url = 'https://pai.direct/flash.ps1'
irm "$url.sha256" -OutFile flash.ps1.sha256
irm $url -OutFile flash.ps1
Get-FileHash flash.ps1 -Algorithm SHA256
# Compare the printed hash to flash.ps1.sha256, then:
powershell -ExecutionPolicy Bypass -File .\\flash.ps1`}</code></pre>
          <p>
            The <code>.sha256</code> sidecar is regenerated on every release of
            <code>flash.ps1</code>. Fetch the pair together.
          </p>
        </details>
        <details>
          <summary>Prefer Winget?</summary>
          <pre><code>winget install PAI.PAI</code></pre>
          <p>Ships with Windows 10/11. Gives you the <code>pai</code> command.</p>
        </details>
        <details>
          <summary>Prefer Scoop?</summary>
          <pre><code>{`scoop bucket add pai https://github.com/nirholas/scoop-pai
scoop install pai`}</code></pre>
        </details>
      </section>

      <section id="macos" class="install-section">
        <h2>macOS</h2>
        <ol>
          <li>Download the ISO using the button above.</li>
          <li>Install <a href="https://etcher.balena.io" rel="noreferrer" target="_blank">balenaEtcher</a>.</li>
          <li>Open Etcher, click <strong>Flash from file</strong> and select the ISO.</li>
          <li>Click <strong>Select target</strong>, choose the USB drive, then <strong>Flash!</strong></li>
          <li>Reboot while holding <kbd>Option</kbd> to pick the USB drive (Intel Macs). Apple Silicon Macs are not yet supported.</li>
        </ol>
        <details>
          <summary>Prefer Homebrew?</summary>
          <pre><code>brew install nirholas/tap/pai
pai flash    # interactive flasher
pai try      # launch PAI in a VM
pai --help   # all subcommands</code></pre>
        </details>
      </section>

      <section id="linux" class="install-section">
        <h2>Linux</h2>
        <ol>
          <li>Download the ISO using the button above.</li>
          <li>Install <a href="https://etcher.balena.io" rel="noreferrer" target="_blank">balenaEtcher</a> (GUI) or use <code>dd</code> from the console section below.</li>
          <li>Open Etcher → <strong>Flash from file</strong> → pick the ISO.</li>
          <li>Select your USB drive as the target, then click <strong>Flash!</strong></li>
          <li>Reboot and pick the USB drive from your BIOS/UEFI boot menu.</li>
        </ol>        <details>
          <summary>Prefer Homebrew?</summary>
          <pre><code>brew install pai/tap/pai
pai flash    # interactive flasher
pai try      # launch PAI in a VM
pai --help   # all subcommands</code></pre>
        </details>        <details>
          <summary>Arch Linux (AUR)</summary>
          <pre><code>yay -S pai-cli
# bleeding-edge:
yay -S pai-cli-git</code></pre>
        </details>
      </section>

      <section id="console" class="install-section">
        <h2>Console (Windows / Linux / macOS)</h2>
        <p class="warn">
          ⚠ Double-check the device path before running <code>dd</code> or
          <code>flash.ps1</code> — the wrong path will permanently destroy data on
          that drive.
        </p>
        <h3>Windows (PowerShell as Administrator)</h3>
        <pre><code>irm https://pai.direct/flash.ps1 | iex</code></pre>
        <h3>Linux</h3>
        <pre><code>lsblk
sudo dd if={release.isoName} of=/dev/sdX bs=4M status=progress conv=fsync</code></pre>
        <h3>macOS</h3>
        <pre><code>diskutil list
sudo dd if={release.isoName} of=/dev/rdiskN bs=4m</code></pre>
      </section>

      <section id="raspberry-pi" class="install-section">
        <h2>Raspberry Pi</h2>
        <p>
          Use <a href="https://www.raspberrypi.com/software/" rel="noreferrer" target="_blank">Raspberry Pi Imager</a>.
          Open Imager → press <kbd>Ctrl+Shift+X</kbd> → enable <strong>Use custom repository</strong> →
          paste:
        </p>
        <pre><code>https://pai.direct/imager.json</code></pre>
        <p>
          PAI appears in the OS list. Pick your Pi model, choose your SD card or USB drive, and flash.
        </p>
        <p>
          <a href="https://docs.pai.direct/first-steps/using-raspberry-pi-imager" class="install-link">
            Full Raspberry Pi install guide →
          </a>
        </p>
      </section>

      <section id="ventoy" class="install-section">
        <h2>Ventoy — drag-and-drop (no wipe)</h2>
        <p>
          <a href="https://www.ventoy.net" rel="noreferrer" target="_blank">Ventoy</a>
          lets you boot PAI by dropping the ISO onto a USB drive instead of flashing.
          Install Ventoy once, then carry PAI alongside other ISOs and upgrade by
          copying a new release on top.
        </p>
        <ol>
          <li>Install Ventoy on your USB: download from <a href="https://www.ventoy.net/en/download.html" rel="noreferrer" target="_blank">ventoy.net</a>.</li>
          <li>Drag <code>{release.isoName}</code> onto the Ventoy drive.</li>
          <li>Reboot, pick the Ventoy drive from the boot menu, select PAI.</li>
        </ol>
        <p>
          <a href="https://docs.pai.direct/first-steps/using-ventoy" class="install-link">
            Full Ventoy guide →
          </a>
        </p>
      </section>

      <section class="install-section">
        <h2>Other options</h2>
        <ul>
          <li><a href="/apps/verify">Verify the ISO signature before flashing</a></li>
          <li><a href="https://docs.pai.direct/vm" target="_blank" rel="noopener">Run PAI in a virtual machine</a></li>
        </ul>
      </section>
    </main>

    <footer class="install-footer">
      <div class="install-container">
        <p>
          PAI is free software under the <a href="https://www.gnu.org/licenses/gpl-3.0.html">GPL v3</a>.
          Source on <a href="https://github.com/nirholas/pai">GitHub</a>.
        </p>
      </div>
    </footer>

    <style>
      .install-body {
        background: var(--bg);
        color: var(--fg);
        font-family: var(--font-ui, system-ui, sans-serif);
        line-height: 1.55;
      }
      .install-container { max-width: 960px; margin: 0 auto; padding: 0 1.25rem; }
      .skip-link {
        position: absolute; left: -9999px; top: 0;
      }
      .skip-link:focus { left: 1rem; top: 1rem; background: var(--pai-blue); color: #0f0f1a; padding: 0.5rem 0.75rem; border-radius: 4px; z-index: 10; }

      .install-topbar { background: #1a1a2e; border-bottom: 1px solid var(--border, #2a2a3e); }
      .install-topbar__inner {
        display: flex; align-items: center; justify-content: space-between;
        gap: 1.5rem; padding-top: 0.85rem; padding-bottom: 0.85rem;
      }
      .install-brand { display: inline-flex; align-items: center; gap: 0.5rem; color: var(--fg); text-decoration: none; font-weight: 700; font-size: 1.1rem; }
      .install-brand__logo { color: var(--pai-blue); font-size: 1.25rem; }
      .install-nav { display: flex; gap: 1.25rem; flex-wrap: wrap; }
      .install-nav a { color: var(--fg-muted, #a0a0b0); text-decoration: none; font-size: 0.95rem; padding: 0.25rem 0; border-bottom: 2px solid transparent; }
      .install-nav a:hover { color: var(--fg); }
      .install-nav a.is-active { color: var(--pai-blue); border-bottom-color: var(--pai-blue); }

      .install-main { padding: 2.5rem 1.25rem 4rem; }
      .install-title { font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 700; margin: 0 0 0.5rem; }
      .install-lede { color: var(--fg-muted, #a0a0b0); margin: 0 0 2rem; font-size: 1.05rem; }

      .os-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1rem;
        margin-bottom: 1.75rem;
      }
      .os-card {
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        gap: 0.6rem;
        background: color-mix(in srgb, var(--pai-green, #4ade80) 18%, #0f0f1a);
        border: 1px solid color-mix(in srgb, var(--pai-green, #4ade80) 40%, transparent);
        border-radius: var(--r-window, 10px);
        color: var(--fg);
        text-decoration: none;
        padding: 1.6rem 1rem;
        min-height: 160px;
        text-align: center;
        transition: transform 0.12s ease, box-shadow 0.12s ease, border-color 0.12s ease;
      }
      .os-card:hover {
        transform: translateY(-2px);
        border-color: var(--pai-green, #4ade80);
        box-shadow: 0 6px 18px -6px color-mix(in srgb, var(--pai-green, #4ade80) 40%, transparent);
      }
      .os-card__icon { color: var(--fg); }
      .os-card__label { font-weight: 700; font-size: 1.05rem; }
      .os-card__sub { font-size: 0.8rem; color: var(--fg-muted, #a0a0b0); line-height: 1.4; }
      .os-card__sub code { font-family: var(--font-mono, ui-monospace, monospace); font-size: 0.78rem; }

      .install-download { margin: 0 0 0.4rem; }
      .install-download a { color: var(--pai-green, #4ade80); font-weight: 600; text-decoration: none; }
      .install-download a:hover { text-decoration: underline; }
      .install-version { color: var(--fg-muted, #a0a0b0); margin: 0 0 2rem; font-size: 0.95rem; }
      .install-version a { color: var(--pai-green, #4ade80); }
      .install-size { opacity: 0.8; }

      .install-callout {
        display: flex; gap: 1rem; align-items: flex-start;
        background: var(--bg-elev, #12121f);
        border: 1px solid var(--border, #2a2a3e);
        border-radius: var(--r-window, 10px);
        padding: 1rem 1.15rem;
        margin: 1.25rem 0;
      }
      .install-callout p { margin: 0 0 0.5rem; }
      .install-callout p:last-child { margin-bottom: 0; }
      .install-callout ul { margin: 0; padding-left: 1.1rem; }
      .install-callout a { color: var(--pai-green, #4ade80); }
      .install-callout__icon {
        flex-shrink: 0;
        width: 2rem; height: 2rem;
        border-radius: 50%;
        background: color-mix(in srgb, var(--pai-blue, #7aa2f7) 25%, transparent);
        color: var(--pai-blue, #7aa2f7);
        display: flex; align-items: center; justify-content: center;
        font-weight: 700;
      }
      .install-callout--muted .install-callout__icon {
        background: color-mix(in srgb, var(--fg-muted, #a0a0b0) 20%, transparent);
        color: var(--fg-muted, #a0a0b0);
      }

      .install-link { color: var(--pai-blue, #7aa2f7); text-decoration: none; }
      .install-link:hover { text-decoration: underline; }

      .install-section { margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px solid var(--border, #2a2a3e); }
      .install-section h2 { font-size: 1.4rem; margin: 0 0 0.75rem; }
      .install-section h3 { font-size: 1rem; margin: 1rem 0 0.4rem; color: var(--fg-muted, #a0a0b0); }
      .install-section ol, .install-section ul { padding-left: 1.25rem; }
      .install-section li { margin-bottom: 0.4rem; }
      .install-section a { color: var(--pai-blue, #7aa2f7); }
      .install-section pre {
        background: var(--bg-elev, #12121f);
        border: 1px solid var(--border, #2a2a3e);
        border-radius: 6px;
        padding: 0.75rem 0.9rem;
        overflow-x: auto;
        font-family: var(--font-mono, ui-monospace, monospace);
        font-size: 0.85rem;
        color: var(--pai-green, #4ade80);
      }
      .install-section code { font-family: var(--font-mono, ui-monospace, monospace); font-size: 0.9em; }
      .install-section .warn {
        background: #2a1800; border: 1px solid #5c3600;
        color: #fbbf24; padding: 0.55rem 0.8rem; border-radius: 6px;
      }
      kbd {
        font-family: var(--font-mono, ui-monospace, monospace);
        font-size: 0.8125rem;
        background: var(--bg-elev, #12121f);
        border: 1px solid var(--border, #2a2a3e);
        border-radius: 4px;
        padding: 1px 5px;
      }

      .install-footer {
        border-top: 1px solid var(--border, #2a2a3e);
        padding: 1.5rem 0;
        color: var(--fg-muted, #a0a0b0);
        font-size: 0.9rem;
      }
      .install-footer a { color: var(--pai-blue, #7aa2f7); }

      @media (max-width: 640px) {
        .install-topbar__inner { flex-direction: column; align-items: flex-start; gap: 0.75rem; }
        .install-nav { gap: 0.9rem; }
      }
    </style>

    <script>
      import { initSiteMenu } from '../shell/site-menu.ts'
      initSiteMenu()

      // Highlight the OS card that matches the visitor's platform.
      const platform =
        (navigator as Navigator & { userAgentData?: { platform: string } })
          .userAgentData?.platform ?? navigator.platform ?? ''
      const os = /mac/i.test(platform)
        ? 'mac'
        : /win/i.test(platform)
          ? 'windows'
          : /linux/i.test(platform)
            ? 'linux'
            : null
      if (os) {
        const card = document.querySelector<HTMLElement>(`.os-card[data-os="${os}"]`)
        if (card) card.style.outline = '2px solid var(--pai-blue, #7aa2f7)'
      }
    </script>
  </body>
</html>
