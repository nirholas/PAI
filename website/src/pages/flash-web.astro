---
import '../styles/global.css'
import release from '../data/release.json'
import Stepper from '../components/flash-web/Stepper.astro'
import StepDetect from '../components/flash-web/StepDetect.astro'
import StepDownload from '../components/flash-web/StepDownload.astro'
import StepMethod from '../components/flash-web/StepMethod.astro'
import StepFlash from '../components/flash-web/StepFlash.astro'
import StepBoot from '../components/flash-web/StepBoot.astro'

const title = 'Browser Installer — PAI'
const description =
  'Download, verify, and flash PAI to a USB drive — entirely from your browser. No tools required.'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/logo/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/logo/favicon-32.png" />
  </head>
  <body class="flash-body">
    <a href="#flash-main" class="skip-link">Skip to main content</a>

    <header class="flash-topbar">
      <div class="flash-container flash-topbar__inner">
        <a class="flash-brand" href="/" aria-label="PAI home">
          <span class="flash-brand__logo" aria-hidden="true">◆</span>
          <span class="flash-brand__name">PAI</span>
        </a>
        <nav class="flash-nav" aria-label="Primary">
          <a href="/">Home</a>
          <a href="/install">Install PAI</a>
          <a href="/flash-web" aria-current="page" class="is-active">Browser Installer</a>
        </nav>
      </div>
    </header>

    <main id="flash-main" class="flash-container flash-main">
      <h1 class="flash-title">Browser Installer</h1>
      <p class="flash-lede">
        Download, verify, and flash PAI to a USB drive — entirely from your browser.
      </p>

      <div class="flash-app" id="flash-app">
        <Stepper />
        <div class="step-panels" id="step-panels">
          <StepDetect />
          <StepDownload />
          <StepMethod />
          <StepFlash />
          <StepBoot />
        </div>
        <div class="sr-only" aria-live="polite" id="step-announcer"></div>
      </div>
    </main>

    <footer class="flash-footer">
      <div class="flash-container">
        <p>
          This page runs entirely in your browser. PAI does not track visits or log errors.
        </p>
        <p>
          PAI is free software, released under the GPLv3.
          Source on <a href="https://github.com/nirholas/pai" target="_blank" rel="noreferrer">GitHub ↗</a>.
        </p>
      </div>
    </footer>

    <script>
      // =========================================================
      // PAI Browser Installer — Client-side application logic
      // =========================================================

      (function () {
        'use strict';

        // --- State ---
        let currentStep = 1;
        let detectedOS = 'unknown';
        let isoBlob = null;
        let isoFilename = '';
        let selectedMethod = 'quick';
        let sha256Worker = null;

        const releaseData = window.__PAI_RELEASE__ || {
          downloadUrl: '',
          expectedSha256: '',
          isoName: '',
        };

        // --- DOM helpers ---
        const $ = (sel) => document.querySelector(sel);
        const $$ = (sel) => [...document.querySelectorAll(sel)];

        // --- Step navigation ---
        function goToStep(step) {
          if (step < 1 || step > 5) return;
          currentStep = step;

          // Update stepper tabs
          $$('.stepper__step').forEach((btn) => {
            const s = Number(btn.dataset.step);
            btn.setAttribute('aria-selected', s === step ? 'true' : 'false');
            btn.tabIndex = s === step ? 0 : -1;
            if (s < step) btn.classList.add('completed');
          });

          // Update panels
          $$('.step-panel').forEach((panel) => {
            const id = panel.id; // step-panel-N
            const n = Number(id.split('-').pop());
            if (n === step) {
              panel.setAttribute('data-active', '');
            } else {
              panel.removeAttribute('data-active');
            }
          });

          // URL hash
          history.replaceState(null, '', `#step-${step}`);

          // Screen reader announcement
          const labels = ['', 'Detect & Prep', 'Download & Verify', 'Choose Method', 'Flash', 'Boot'];
          const announcer = $('#step-announcer');
          if (announcer) announcer.textContent = `Step ${step}: ${labels[step]}`;
        }

        // --- OS Detection ---
        function detectOS() {
          const p = navigator.userAgentData?.platform ?? navigator.platform ?? '';
          if (/windows/i.test(p)) return 'windows';
          if (/mac|darwin/i.test(p)) return 'macos';
          if (/linux/i.test(p)) return 'linux';
          return 'unknown';
        }

        // --- Pre-flight checks ---
        function runPreflight() {
          detectedOS = detectOS();
          const osNames = { windows: 'Windows', macos: 'macOS', linux: 'Linux', unknown: 'Unknown' };

          setCheck('os', 'pass', osNames[detectedOS] || 'Unknown');

          // SubtleCrypto / Worker
          const hasCrypto = typeof Worker !== 'undefined';
          setCheck('crypto', hasCrypto ? 'pass' : 'fail', hasCrypto ? 'Available (Web Worker)' : 'Not available');

          // Streaming
          const hasStream = typeof ReadableStream !== 'undefined' && typeof Response !== 'undefined';
          setCheck('stream', hasStream ? 'pass' : 'fail', hasStream ? 'Supported' : 'Not supported');

          // WebUSB
          const hasUsb = 'usb' in navigator;
          setCheck('usb', hasUsb ? 'pass' : 'warn', hasUsb ? 'Available' : 'Not available (OK — use Quick method)');

          // File System Access
          const hasFs = 'showSaveFilePicker' in window;
          setCheck('fs', hasFs ? 'pass' : 'warn', hasFs ? 'Available' : 'Not available (will use fallback download)');

          // Enable continue if essentials pass
          const canProceed = hasCrypto && hasStream;
          const btn = $('#btn-start-download');
          if (btn) btn.disabled = !canProceed;

          // Show WebUSB method card if available
          const webusbCard = $('#method-webusb');
          if (webusbCard && hasUsb) webusbCard.hidden = false;
        }

        function setCheck(name, status, value) {
          const item = $(`.check-item[data-check="${name}"]`);
          if (!item) return;
          item.className = `check-item ${status}`;
          const val = item.querySelector('.check-value');
          if (val) val.textContent = value;
        }

        // --- Download & Verify ---
        async function startDownload() {
          const statusEl = $('#verify-status');
          const errorEl = $('#download-error');
          const errorMsg = $('#download-error-msg');
          const progressFill = $('#progress-fill');
          const progressPct = $('#progress-pct');
          const progressSpeed = $('#progress-speed');
          const progressEta = $('#progress-eta');
          const sizeEl = $('#download-size');
          const continueBtn = $('#btn-continue-method');
          const startBtn = $('#btn-start-download-action');

          if (startBtn) startBtn.disabled = true;
          if (errorEl) errorEl.hidden = true;

          try {
            if (statusEl) {
              statusEl.textContent = 'Starting download…';
              statusEl.className = 'verify-status';
            }

            const url = releaseData.downloadUrl;
            const response = await fetch(url);
            if (!response.ok) throw new Error(`HTTP ${response.status}: ${response.statusText}`);

            const total = Number(response.headers.get('content-length') || 0);
            if (sizeEl && total > 0) {
              sizeEl.textContent = formatBytes(total);
            }

            // Init SHA256 worker (served from /sha256-worker.js in public/)
            sha256Worker = new Worker('/sha256-worker.js');

            await new Promise((resolve, reject) => {
              sha256Worker.onmessage = (e) => {
                if (e.data.type === 'ready') resolve();
                else if (e.data.type === 'error') reject(new Error(e.data.message));
              };
              sha256Worker.postMessage({ type: 'init' });
            });

            // Stream download
            const reader = response.body.getReader();
            const chunks = [];
            let received = 0;
            const startTime = performance.now();

            while (true) {
              const { done, value } = await reader.read();
              if (done) break;

              chunks.push(value);
              received += value.length;

              // Clone the buffer for the worker (original stays in chunks for blob assembly)
              const copy = value.buffer.slice(value.byteOffset, value.byteOffset + value.byteLength);
              sha256Worker.postMessage({ type: 'update', data: copy }, [copy]);

              const elapsed = (performance.now() - startTime) / 1000;
              const pct = total > 0 ? Math.round((received / total) * 100) : 0;
              const speed = received / elapsed;
              const eta = total > 0 ? Math.round((total - received) / speed) : 0;

              if (progressFill) {
                progressFill.style.width = `${pct}%`;
                progressFill.setAttribute('aria-valuenow', String(pct));
              }
              if (progressPct) progressPct.textContent = `${pct}%`;
              if (progressSpeed) progressSpeed.textContent = `${formatBytes(speed)}/s`;
              if (progressEta) progressEta.textContent = total > 0 ? formatTime(eta) : '—';
            }

            if (statusEl) statusEl.textContent = 'Verifying SHA256 checksum…';

            // Get digest
            const hex = await new Promise((resolve, reject) => {
              sha256Worker.onmessage = (e) => {
                if (e.data.type === 'digest') resolve(e.data.hex);
                else if (e.data.type === 'error') reject(new Error(e.data.message));
              };
              sha256Worker.postMessage({ type: 'digest' });
            });

            sha256Worker.terminate();
            sha256Worker = null;

            // Verify
            const expected = releaseData.expectedSha256;
            if (expected && expected !== 'not-yet-released' && hex.toLowerCase() !== expected.toLowerCase()) {
              throw new Error(`SHA256 mismatch!\nExpected: ${expected}\nGot: ${hex}`);
            }

            // Build blob
            isoBlob = new Blob(chunks);
            isoFilename = releaseData.isoName || 'pai.iso';

            if (statusEl) {
              statusEl.textContent = `✓ Verified — SHA256: ${hex.slice(0, 16)}…`;
              statusEl.className = 'verify-status success';
            }

            // Save file
            await saveFile(isoBlob, isoFilename);

            if (continueBtn) continueBtn.hidden = false;

          } catch (err) {
            if (sha256Worker) {
              sha256Worker.terminate();
              sha256Worker = null;
            }
            if (statusEl) {
              statusEl.textContent = 'Verification failed';
              statusEl.className = 'verify-status error';
            }
            if (errorEl) errorEl.hidden = false;
            if (errorMsg) errorMsg.textContent = err.message || String(err);
            if (startBtn) startBtn.disabled = false;
          }
        }

        async function saveFile(blob, filename) {
          if ('showSaveFilePicker' in window) {
            try {
              const handle = await window.showSaveFilePicker({
                suggestedName: filename,
                types: [{
                  description: 'ISO Image',
                  accept: { 'application/octet-stream': ['.iso'] },
                }],
              });
              const writable = await handle.createWritable();
              await writable.write(blob);
              await writable.close();
              return;
            } catch (e) {
              if (e.name === 'AbortError') return; // User cancelled
              // Fall through to download fallback
            }
          }

          // Fallback
          const url = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = filename;
          document.body.appendChild(a);
          a.click();
          document.body.removeChild(a);
          setTimeout(() => URL.revokeObjectURL(url), 60000);
        }

        // --- One-liner generation ---
        function generateCommand(os) {
          const filename = isoFilename || releaseData.isoName || 'pai.iso';
          const hash = releaseData.expectedSha256 || '<sha256>';

          switch (os) {
            case 'windows':
              return [
                `# Run in PowerShell as Administrator`,
                `irm https://pai.direct/flash.ps1 -OutFile flash.ps1`,
                `powershell -ExecutionPolicy Bypass -File .\\flash.ps1 -LocalIso "$env:USERPROFILE\\Downloads\\${filename}"`,
              ].join('\n');

            case 'macos':
              return [
                `# Run in Terminal — will ask for your password`,
                `curl -fsSL https://pai.direct/flash.sh | sudo bash -s -- --local-iso ~/Downloads/${filename}`,
              ].join('\n');

            case 'linux':
              return [
                `# Run in Terminal — will ask for your password`,
                `curl -fsSL https://pai.direct/flash.sh | sudo bash -s -- --local-iso ~/Downloads/${filename}`,
              ].join('\n');

            default:
              return [
                `# Download the ISO, then run one of:`,
                `# Linux/macOS:`,
                `curl -fsSL https://pai.direct/flash.sh | sudo bash -s -- --local-iso ~/Downloads/${filename}`,
                `# Windows (PowerShell as Admin):`,
                `irm https://pai.direct/flash.ps1 -OutFile flash.ps1`,
                `powershell -ExecutionPolicy Bypass -File .\\flash.ps1 -LocalIso "$env:USERPROFILE\\Downloads\\${filename}"`,
              ].join('\n');
          }
        }

        function showFlashQuick() {
          const section = $('#flash-quick');
          const command = $('#flash-command code');
          const note = $('#command-note');
          const continueBtn = $('#btn-continue-boot');

          if (section) section.hidden = false;
          $('#flash-webusb')?.setAttribute('hidden', '');
          $('#flash-manual')?.setAttribute('hidden', '');

          if (command) command.textContent = generateCommand(detectedOS);

          const osNotes = {
            windows: 'Right-click PowerShell → "Run as Administrator" before pasting.',
            macos: 'Open Terminal.app (⌘ + Space, type "Terminal"). You\'ll be prompted for your password.',
            linux: 'Open your terminal emulator. You\'ll be prompted for your sudo password.',
            unknown: 'Use the appropriate terminal for your operating system.',
          };
          if (note) note.textContent = osNotes[detectedOS] || osNotes.unknown;
          if (continueBtn) continueBtn.hidden = false;
        }

        function showFlashWebUsb() {
          const section = $('#flash-webusb');
          if (section) section.hidden = false;
          $('#flash-quick')?.setAttribute('hidden', '');
          $('#flash-manual')?.setAttribute('hidden', '');
        }

        function showFlashManual() {
          const section = $('#flash-manual');
          if (section) section.hidden = false;
          $('#flash-quick')?.setAttribute('hidden', '');
          $('#flash-webusb')?.setAttribute('hidden', '');
          $('#btn-continue-boot').hidden = false;
        }

        // --- WebUSB write ---
        async function startWebUsbWrite() {
          const statusEl = $('#webusb-status');
          const progressEl = $('#webusb-progress');
          const progressFill = $('#webusb-progress-fill');
          const errorEl = $('#webusb-error');
          const errorMsg = $('#webusb-error-msg');
          const warningEl = $('#webusb-warning');

          if (!isoBlob) {
            if (errorEl) errorEl.hidden = false;
            if (errorMsg) errorMsg.textContent = 'No ISO downloaded. Go back and download first.';
            return;
          }

          try {
            const device = await navigator.usb.requestDevice({ filters: [] });
            await device.open();

            // Check for mass storage interface (class 8)
            let iface = null;
            for (const config of device.configurations) {
              for (const intf of config.interfaces) {
                for (const alt of intf.alternates) {
                  if (alt.interfaceClass === 8) { // Mass Storage
                    iface = intf;
                    break;
                  }
                }
                if (iface) break;
              }
              if (iface) break;
            }

            if (!iface) {
              throw new Error(
                'Selected device does not appear to be a USB mass storage device. ' +
                'Please select a USB flash drive.'
              );
            }

            try {
              await device.claimInterface(iface.interfaceNumber);
            } catch (e) {
              throw new Error(
                'Could not claim the USB device. Your OS is holding the USB driver. ' +
                'Close any File Explorer/Finder window showing the drive, unmount it, ' +
                'or try the Quick method instead.\n\nTechnical: ' + e.message
              );
            }

            if (warningEl) warningEl.hidden = true;
            if (progressEl) progressEl.hidden = false;

            // Find bulk OUT endpoint
            let endpoint = null;
            for (const alt of iface.alternates) {
              for (const ep of alt.endpoints) {
                if (ep.direction === 'out' && ep.type === 'bulk') {
                  endpoint = ep;
                  break;
                }
              }
              if (endpoint) break;
            }

            if (!endpoint) {
              throw new Error('No bulk OUT endpoint found on the device.');
            }

            // Write in 4 MiB chunks
            const CHUNK_SIZE = 4 * 1024 * 1024;
            const totalSize = isoBlob.size;
            let offset = 0;
            const arrayBuffer = await isoBlob.arrayBuffer();

            while (offset < totalSize) {
              const end = Math.min(offset + CHUNK_SIZE, totalSize);
              const chunk = new Uint8Array(arrayBuffer, offset, end - offset);

              // Build SCSI WRITE(16) CDB — this is a simplified version
              const lba = Math.floor(offset / 512);
              const blocks = Math.ceil(chunk.length / 512);

              // CBW (Command Block Wrapper) for USB mass storage
              const cbw = new Uint8Array(31);
              const cbwView = new DataView(cbw.buffer);
              cbwView.setUint32(0, 0x55534243, false); // Signature
              cbwView.setUint32(4, offset, true); // Tag
              cbwView.setUint32(8, chunk.length, true); // Transfer length
              cbw[12] = 0x00; // Direction: OUT
              cbw[13] = 0; // LUN
              cbw[14] = 16; // CDB length

              // SCSI WRITE(16) CDB
              cbw[15] = 0x8A; // WRITE(16) opcode
              // LBA (8 bytes, big-endian)
              cbwView.setUint32(17, 0, false); // High 32 bits of LBA
              cbwView.setUint32(21, lba, false); // Low 32 bits of LBA
              cbwView.setUint32(25, blocks, false); // Transfer length in blocks

              await device.transferOut(endpoint.endpointNumber, cbw);
              await device.transferOut(endpoint.endpointNumber, chunk);

              offset = end;
              const pct = Math.round((offset / totalSize) * 100);
              if (progressFill) {
                progressFill.style.width = `${pct}%`;
                progressFill.setAttribute('aria-valuenow', String(pct));
              }
              if (statusEl) statusEl.textContent = `Writing… ${pct}% (${formatBytes(offset)} / ${formatBytes(totalSize)})`;
            }

            await device.releaseInterface(iface.interfaceNumber);
            await device.close();

            if (statusEl) statusEl.textContent = '✓ Write complete! Safely eject the drive before removing it.';
            $('#btn-continue-boot').hidden = false;

          } catch (err) {
            if (err.name === 'NotFoundError') return; // User cancelled picker
            if (errorEl) errorEl.hidden = false;
            if (errorMsg) errorMsg.textContent = err.message || String(err);
            if (progressEl) progressEl.hidden = true;
          }
        }

        // --- Utility ---
        function formatBytes(bytes) {
          if (bytes < 1024) return bytes + ' B';
          if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
          if (bytes < 1024 * 1024 * 1024) return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
          return (bytes / (1024 * 1024 * 1024)).toFixed(2) + ' GB';
        }

        function formatTime(seconds) {
          if (seconds < 60) return `${seconds}s`;
          const m = Math.floor(seconds / 60);
          const s = seconds % 60;
          return `${m}m ${s}s`;
        }

        // --- Copy to clipboard ---
        async function copyToClipboard(text, btn) {
          try {
            await navigator.clipboard.writeText(text);
            if (btn) {
              btn.classList.add('copied');
              const orig = btn.innerHTML;
              btn.innerHTML = btn.innerHTML.replace('Copy', 'Copied!');
              setTimeout(() => {
                btn.classList.remove('copied');
                btn.innerHTML = orig;
              }, 2000);
            }
          } catch {
            // Fallback for non-secure contexts
            const ta = document.createElement('textarea');
            ta.value = text;
            ta.style.position = 'fixed';
            ta.style.opacity = '0';
            document.body.appendChild(ta);
            ta.select();
            document.execCommand('copy');
            document.body.removeChild(ta);
          }
        }

        // --- Event wiring ---
        function init() {
          // Step navigation via stepper buttons
          $$('.stepper__step').forEach((btn) => {
            btn.addEventListener('click', () => {
              const step = Number(btn.dataset.step);
              if (step <= currentStep) goToStep(step);
            });
          });

          // Keyboard nav on stepper
          $$('.stepper__step').forEach((btn) => {
            btn.addEventListener('keydown', (e) => {
              const steps = $$('.stepper__step');
              const idx = steps.indexOf(btn);
              let target = null;
              if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
                target = steps[idx + 1];
              } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
                target = steps[idx - 1];
              } else if (e.key === 'Home') {
                target = steps[0];
              } else if (e.key === 'End') {
                target = steps[steps.length - 1];
              }
              if (target) {
                e.preventDefault();
                target.focus();
                target.click();
              }
            });
          });

          // Step 1 → 2
          $('#btn-start-download')?.addEventListener('click', () => goToStep(2));

          // Step 2 actions
          $('#btn-back-to-detect')?.addEventListener('click', () => goToStep(1));
          $('#btn-start-download-action')?.addEventListener('click', startDownload);
          $('#btn-retry-download')?.addEventListener('click', startDownload);
          $('#btn-continue-method')?.addEventListener('click', () => goToStep(3));

          // Copy error details
          $('#btn-copy-error')?.addEventListener('click', () => {
            const msg = $('#download-error-msg')?.textContent || '';
            copyToClipboard(msg, $('#btn-copy-error'));
          });

          // Step 3 — method selection
          $('#method-quick')?.addEventListener('click', () => {
            selectedMethod = 'quick';
            goToStep(4);
            showFlashQuick();
          });
          $('#method-webusb')?.addEventListener('click', () => {
            selectedMethod = 'webusb';
            goToStep(4);
            showFlashWebUsb();
          });
          $('#method-manual')?.addEventListener('click', () => {
            selectedMethod = 'manual';
            goToStep(4);
            showFlashManual();
          });

          // Step 3 back
          $('#btn-back-to-download')?.addEventListener('click', () => goToStep(2));

          // Step 4 actions
          $('#btn-back-to-method')?.addEventListener('click', () => goToStep(3));
          $('#btn-continue-boot')?.addEventListener('click', () => goToStep(5));

          // Copy command
          $('#btn-copy-command')?.addEventListener('click', () => {
            const code = $('#flash-command code')?.textContent || '';
            copyToClipboard(code, $('#btn-copy-command'));
          });

          // WebUSB
          $('#webusb-accept-checkbox')?.addEventListener('change', (e) => {
            const btn = $('#btn-webusb-start');
            if (btn) btn.disabled = !e.target.checked;
          });
          $('#btn-webusb-start')?.addEventListener('click', startWebUsbWrite);
          $('#btn-webusb-fallback')?.addEventListener('click', () => {
            showFlashQuick();
          });

          // Initial state
          const hash = location.hash;
          const match = hash.match(/^#step-(\d)$/);
          const startStep = match ? Math.min(Number(match[1]), 1) : 1; // Can only deep-link to step 1 initially
          goToStep(startStep);
          runPreflight();

          // Register service worker
          if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/flash-web-sw.js').catch(() => {});
          }
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else {
          init();
        }
      })();
    </script>

    <style>
      /* ---- Page layout ---- */
      .flash-body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        background: #0b0b12;
        color: #e0e0e0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      .flash-container {
        max-width: 860px;
        margin: 0 auto;
        padding: 0 24px;
        width: 100%;
        box-sizing: border-box;
      }
      .flash-main {
        flex: 1;
        padding-top: 2rem;
        padding-bottom: 3rem;
      }
      .flash-title {
        font-size: 2rem;
        font-weight: 700;
        margin: 0 0 0.5rem;
      }
      .flash-lede {
        color: #aaa;
        font-size: 1.05rem;
        margin: 0 0 2rem;
      }

      /* ---- Topbar ---- */
      .flash-topbar {
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        padding: 14px 0;
      }
      .flash-topbar__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .flash-brand {
        display: flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        color: #e0e0e0;
        font-weight: 700;
        font-size: 1.1rem;
      }
      .flash-brand__logo { color: #38bdf8; }
      .flash-nav { display: flex; gap: 20px; font-size: 0.9rem; }
      .flash-nav a {
        text-decoration: none;
        color: #888;
        transition: color 0.15s;
      }
      .flash-nav a:hover { color: #e0e0e0; }
      .flash-nav a.is-active { color: #38bdf8; }

      /* ---- Footer ---- */
      .flash-footer {
        border-top: 1px solid rgba(255, 255, 255, 0.06);
        padding: 1.5rem 0;
        margin-top: auto;
      }
      .flash-footer p {
        margin: 0.25rem 0;
        font-size: 0.8rem;
        color: #666;
      }
      .flash-footer a { color: #38bdf8; }

      /* ---- Skip link ---- */
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        padding: 8px 16px;
        background: #38bdf8;
        color: #0b0b12;
        z-index: 100;
        font-size: 0.9rem;
        border-radius: 0 0 6px 0;
      }
      .skip-link:focus {
        left: 0;
      }

      /* ---- Buttons ---- */
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 10px 20px;
        border: none;
        border-radius: 8px;
        font: inherit;
        font-size: 0.9rem;
        cursor: pointer;
        text-decoration: none;
        transition: background 0.15s, opacity 0.15s;
      }
      .btn:disabled {
        opacity: 0.4;
        cursor: not-allowed;
      }
      .btn--primary {
        background: #38bdf8;
        color: #0b0b12;
        font-weight: 600;
      }
      .btn--primary:hover:not(:disabled) {
        background: #22d3ee;
      }
      .btn--secondary {
        background: rgba(255, 255, 255, 0.06);
        color: #ccc;
      }
      .btn--secondary:hover:not(:disabled) {
        background: rgba(255, 255, 255, 0.1);
      }
      .btn--ghost {
        background: transparent;
        color: #888;
      }
      .btn--ghost:hover {
        color: #e0e0e0;
      }

      /* ---- Step actions ---- */
      .step-actions {
        display: flex;
        gap: 12px;
        margin-top: 1.5rem;
      }

      /* ---- Screen reader only ---- */
      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      /* ---- Responsive ---- */
      @media (max-width: 640px) {
        .flash-title { font-size: 1.5rem; }
        .flash-nav { gap: 12px; font-size: 0.8rem; }
        .command-block { padding: 12px; padding-right: 12px; }
        .btn--copy { position: static; margin-top: 8px; }
        .method-grid { grid-template-columns: 1fr; }
      }
    </style>

    <script>
      import { initSiteMenu } from '../shell/site-menu.ts'
      initSiteMenu()
    </script>
  </body>
</html>
