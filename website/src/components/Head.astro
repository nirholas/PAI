---
const SITE_URL = 'https://pai.direct'

interface Props {
  title: string
  description: string
  /**
   * Absolute or root-relative path to OG image (1200×630 PNG).
   * Falls back to the PAI logo until per-app PNGs are generated.
   */
  ogImage?: string
  /** Overrides the canonical URL; defaults to current page URL. */
  canonical?: string
  /** JSON-LD structured data object, injected as application/ld+json. */
  structuredData?: object
}

const {
  title,
  description,
  ogImage = '/logo/pai-logo.png',
  canonical,
  structuredData,
} = Astro.props

const canonicalUrl = canonical ?? SITE_URL + Astro.url.pathname.replace(/\/$/, '') + '/'
const ogImageUrl = ogImage.startsWith('http') ? ogImage : SITE_URL + ogImage
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="theme-color" content="#0a0a0a" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />

<!-- Favicons -->
<link rel="icon" href="/logo/favicon.ico" />
<link rel="icon" type="image/png" sizes="32x32" href="/logo/favicon-32.png" />
<link rel="icon" type="image/png" sizes="128x128" href="/logo/favicon-128.png" />
<link rel="icon" type="image/png" sizes="256x256" href="/logo/favicon-256.png" />
<link rel="apple-touch-icon" href="/logo/favicon-256.png" />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content="PAI" />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={title} />

<!-- Twitter / X -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />
<meta name="twitter:image:alt" content={title} />

<!-- RSS -->
<link rel="alternate" type="application/rss+xml" title="PAI Changelog" href="/changelog.xml" />

{structuredData && (
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
)}
