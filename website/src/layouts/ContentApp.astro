---
import '../styles/global.css'
import Head from '../components/Head.astro'

interface Props {
  title?: string
  description?: string
  ogImage?: string
  canonical?: string
  structuredData?: object
  toc?: Array<{ text: string; slug: string; depth: number }>
}

import { getLocale, isRTL } from '../i18n/ui'

const {
  title = 'PAI',
  description = 'PAI — Private AI on a bootable USB drive. Offline-first, local LLMs, no telemetry.',
  ogImage,
  canonical,
  structuredData,
  toc = [],
} = Astro.props
const visibleToc = toc.filter((h) => h.depth <= 3)
const locale = getLocale(Astro.url)
const dir = isRTL(locale) ? 'rtl' : 'ltr'
const fullTitle = title === 'PAI' ? 'PAI' : `${title} — PAI`

// Auto-derive OG image from /apps/<id> routes when not explicitly set.
// The /og/[app].png.ts endpoint generates one PNG per APPS id at build time.
const appMatch = Astro.url.pathname.match(/^\/apps\/([^/]+)\/?$/)
const resolvedOgImage = ogImage ?? (appMatch ? `/og/${appMatch[1]}.png` : undefined)
---

<!doctype html>
<html lang={locale} dir={dir}>
  <head>
    <Head
      title={fullTitle}
      description={description}
      ogImage={resolvedOgImage}
      canonical={canonical}
      structuredData={structuredData}
    />
  </head>
  <body class="ca-body">
    <div class={`ca${visibleToc.length > 0 ? ' ca--has-toc' : ''}`}>
      <nav class="ca__sidebar" aria-label="Navigation">
        <slot name="sidebar" />
      </nav>

      <main class="ca__main" id="ca-main">
        <slot />

        <footer class="site-footer" aria-label="Site footer">
          <div class="sf-grid">
            <div class="sf-col">
              <h4>PAI</h4>
              <ul>
                <li><a href="/apps/about">About</a></li>
                <li><a href="/apps/how-it-works">How PAI works</a></li>
                <li><a href="/apps/flash">Install PAI</a></li>
                <li><a href="/apps/docs">Documentation</a></li>
                <li><a href="/apps/hardware">Hardware</a></li>
              </ul>
            </div>

            <div class="sf-col">
              <h4>Support</h4>
              <ul>
                <li><a href="/apps/faq">FAQ</a></li>
                <li><a href="/apps/verify">Verify ISO</a></li>
                <li><a href="/apps/security">Security</a></li>
                <li><a href="/apps/privacy">Privacy</a></li>
                <li><a href="/apps/changelog">Changelog</a></li>
                <li>
                  <a
                    href="https://github.com/nirholas/pai/issues"
                    target="_blank"
                    rel="noopener noreferrer">Report an issue ↗</a
                  >
                </li>
              </ul>
            </div>

            <div class="sf-col">
              <h4>Contribute</h4>
              <ul>
                <li>
                  <a
                    href="https://github.com/nirholas/pai"
                    target="_blank"
                    rel="noopener noreferrer">Source code ↗</a
                  >
                </li>
                <li>
                  <a
                    href="https://github.com/nirholas/pai/blob/main/CONTRIBUTING.md"
                    target="_blank"
                    rel="noopener noreferrer">Contribute ↗</a
                  >
                </li>
                <li>
                  <a
                    href="https://github.com/nirholas/pai/blob/main/LICENSE"
                    target="_blank"
                    rel="noopener noreferrer">License (GPL v3) ↗</a
                  >
                </li>
                <li><a href="/apps/press">Press</a></li>
              </ul>
            </div>

            <div class="sf-col">
              <h4>Project</h4>
              <ul>
                <li><a href="/apps/about#what-pai-is">What PAI is</a></li>
                <li><a href="/apps/about#who-its-for">Who it's for</a></li>
                <li><a href="/apps/about#what-its-not">What it's not</a></li>
              </ul>
              <div class="sf-social" aria-label="Social links">
                <a
                  href="https://github.com/nirholas/pai"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="GitHub"
                  title="GitHub"
                >
                  <svg
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path
                      d="M12 .5C5.73.5.99 5.24.99 11.5c0 4.86 3.15 8.98 7.52 10.44.55.1.75-.24.75-.53 0-.26-.01-1.13-.02-2.05-3.06.67-3.71-1.3-3.71-1.3-.5-1.28-1.23-1.62-1.23-1.62-1-.69.08-.68.08-.68 1.11.08 1.7 1.14 1.7 1.14.99 1.7 2.6 1.21 3.23.92.1-.72.39-1.21.7-1.49-2.44-.28-5-1.22-5-5.43 0-1.2.43-2.18 1.14-2.95-.11-.28-.49-1.4.11-2.92 0 0 .93-.3 3.05 1.13a10.6 10.6 0 0 1 5.56 0c2.12-1.43 3.05-1.13 3.05-1.13.6 1.52.22 2.64.11 2.92.71.77 1.14 1.75 1.14 2.95 0 4.22-2.57 5.15-5.02 5.42.4.34.76 1.02.76 2.06 0 1.49-.01 2.69-.01 3.06 0 .29.2.64.76.53 4.37-1.46 7.51-5.58 7.51-10.44C23.01 5.24 18.27.5 12 .5z"
                    ></path>
                  </svg>
                </a>
              </div>
            </div>
          </div>

          <div class="sf-bottom">
            <div class="sf-brand">
              <span class="sf-pai">PAI</span>
              <span>— Private AI on a bootable USB drive. Released under GPL v3.</span>
            </div>
          </div>
        </footer>
      </main>

      {
        visibleToc.length > 0 && (
          <aside class="ca__toc" aria-label="Table of contents">
            <p class="toc-label">On this page</p>
            <ol class="toc-list">
              {visibleToc.map((h) => (
                <li class={`toc-item toc-h${h.depth}`}>
                  <a href={`#${h.slug}`}>{h.text}</a>
                </li>
              ))}
            </ol>
          </aside>
        )
      }
    </div>

    <footer class="ca__footer">
      <button class="cta cta--primary" data-open-app="Flash">Got it — let's download</button>
      <button class="cta" data-open-app="FAQ">More questions</button>
    </footer>
  </body>
</html>

<style>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  .ca-body {
    margin: 0;
    height: 100dvh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    font-family: var(--font-ui);
    background: var(--bg);
    color: var(--fg);
    font-size: 0.9375rem;
  }

  /* ── Layout grid ─────────────────────────────────────────────── */
  .ca {
    display: flex;
    flex: 1;
    overflow: hidden;
    min-height: 0;
  }

  /* ── Sidebar ─────────────────────────────────────────────────── */
  .ca__sidebar {
    width: 220px;
    flex-shrink: 0;
    overflow-y: auto;
    border-right: 1px solid var(--border);
    padding: var(--s-4) var(--s-3);
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }

  /* sidebar slots */
  :global(.sb-brand) {
    font-family: var(--font-pixel);
    color: var(--pai-yellow);
    font-size: 1rem;
    margin: 0 0 var(--s-4);
    padding: 0 var(--s-2);
    display: block;
  }

  :global(.sb-section) {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin: var(--s-4) 0 var(--s-1);
    padding: 0 var(--s-2);
  }

  :global(.sb-link) {
    display: block;
    padding: 5px var(--s-2);
    border-radius: var(--r-icon);
    color: var(--fg-muted);
    text-decoration: none;
    font-size: 0.875rem;
    line-height: 1.4;
    transition:
      background 0.1s,
      color 0.1s;
  }

  :global(.sb-link:hover) {
    background: var(--bg-elev);
    color: var(--fg);
  }

  :global(.sb-link.active) {
    background: rgba(122, 162, 247, 0.12);
    color: var(--pai-blue);
  }

  :global(.sb-divider) {
    border: none;
    border-top: 1px solid var(--border);
    margin: var(--s-3) 0;
  }

  /* ── Search ──────────────────────────────────────────────────── */
  :global(.sb-search) {
    display: flex;
    align-items: center;
    gap: var(--s-2);
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--r-icon);
    padding: 5px var(--s-2);
    margin-bottom: var(--s-3);
  }

  :global(.sb-search input) {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: var(--fg);
    font-size: 0.8125rem;
    font-family: var(--font-ui);
    min-width: 0;
  }

  :global(.sb-search input::placeholder) {
    color: var(--fg-muted);
  }

  :global(.sb-search-icon) {
    color: var(--fg-muted);
    font-size: 0.75rem;
    flex-shrink: 0;
  }

  :global(.sb-results) {
    position: absolute;
    left: 0;
    top: 100%;
    z-index: 10;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--r-window);
    width: 100%;
    max-height: 300px;
    overflow-y: auto;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
    margin-top: 4px;
  }

  :global(.sb-result) {
    display: block;
    padding: var(--s-2) var(--s-3);
    color: var(--fg);
    text-decoration: none;
    font-size: 0.8125rem;
    border-bottom: 1px solid var(--border);
    transition: background 0.1s;
  }

  :global(.sb-result:last-child) {
    border-bottom: none;
  }

  :global(.sb-result:hover) {
    background: rgba(122, 162, 247, 0.1);
  }

  :global(.sb-result-title) {
    font-weight: 600;
    color: var(--pai-blue);
  }

  :global(.sb-result-section) {
    color: var(--fg-muted);
    font-size: 0.75rem;
  }

  :global(.sb-no-results) {
    padding: var(--s-3);
    color: var(--fg-muted);
    font-size: 0.8125rem;
    text-align: center;
  }

  /* ── Main content ────────────────────────────────────────────── */
  .ca__main {
    flex: 1;
    overflow-y: auto;
    padding: var(--s-6) var(--s-7);
    min-width: 0;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }

  /* Prose */
  .ca__main :global(h1) {
    font-family: var(--font-pixel);
    color: var(--pai-yellow);
    font-size: 1.75rem;
    line-height: 1.2;
    margin: 0 0 var(--s-4);
    max-width: 72ch;
  }

  .ca__main :global(h2) {
    color: var(--pai-blue);
    font-size: 1.25rem;
    font-weight: 600;
    margin: var(--s-7) 0 var(--s-3);
    max-width: 72ch;
    scroll-margin-top: var(--s-4);
  }

  .ca__main :global(h3) {
    color: var(--fg);
    font-size: 1rem;
    font-weight: 600;
    margin: var(--s-5) 0 var(--s-2);
    max-width: 72ch;
    scroll-margin-top: var(--s-4);
  }

  .ca__main :global(h4) {
    color: var(--fg-muted);
    font-size: 0.9375rem;
    font-weight: 600;
    margin: var(--s-4) 0 var(--s-2);
    max-width: 72ch;
  }

  .ca__main :global(p) {
    line-height: 1.6;
    max-width: 72ch;
    margin: 0 0 var(--s-3);
    color: var(--fg);
  }

  .ca__main :global(ul),
  .ca__main :global(ol) {
    padding-left: var(--s-5);
    margin: 0 0 var(--s-4);
    max-width: 72ch;
  }

  .ca__main :global(li) {
    line-height: 1.6;
    margin-bottom: var(--s-1);
    color: var(--fg);
  }

  .ca__main :global(a) {
    color: var(--pai-blue);
    text-underline-offset: 3px;
    text-decoration-color: rgba(122, 162, 247, 0.4);
  }

  .ca__main :global(a:hover) {
    color: var(--pai-yellow);
    text-decoration-color: var(--pai-yellow);
  }

  .ca__main :global(strong) {
    color: var(--fg);
    font-weight: 600;
  }

  .ca__main :global(em) {
    color: var(--fg-muted);
  }

  .ca__main :global(mark) {
    background: var(--pai-yellow);
    color: #0f0f1a;
    padding: 1px 3px;
    border-radius: 2px;
  }

  /* Code */
  .ca__main :global(:not(pre) > code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    padding: 1px 5px;
    border-radius: 4px;
    color: var(--pai-green);
  }

  .ca__main :global(pre) {
    position: relative;
    background: var(--bg-elev) !important;
    border: 1px solid var(--border);
    border-radius: var(--r-window);
    padding: var(--s-4) var(--s-5);
    overflow-x: auto;
    margin: 0 0 var(--s-5);
    max-width: 72ch;
    tab-size: 2;
  }

  .ca__main :global(pre code) {
    font-family: var(--font-mono);
    background: none !important;
    border: none !important;
    padding: 0;
    font-size: 0.875rem;
    line-height: 1.6;
    color: inherit;
  }

  /* Tables */
  .ca__main :global(table) {
    border-collapse: collapse;
    max-width: 72ch;
    width: 100%;
    margin: 0 0 var(--s-5);
    font-size: 0.875rem;
  }

  .ca__main :global(th),
  .ca__main :global(td) {
    border: 1px solid var(--border);
    padding: var(--s-2) var(--s-3);
    text-align: left;
    vertical-align: top;
  }

  .ca__main :global(th) {
    background: var(--bg-elev);
    color: var(--pai-yellow);
    font-weight: 600;
  }

  .ca__main :global(tr:hover td) {
    background: rgba(255, 255, 255, 0.02);
  }

  /* Blockquote */
  .ca__main :global(blockquote) {
    border-left: 3px solid var(--pai-yellow);
    margin: 0 0 var(--s-4);
    padding: var(--s-2) var(--s-4);
    background: rgba(251, 191, 36, 0.05);
    border-radius: 0 var(--r-icon) var(--r-icon) 0;
    max-width: 72ch;
  }

  .ca__main :global(blockquote p) {
    margin: 0;
    color: var(--fg-muted);
  }

  /* Images */
  .ca__main :global(img) {
    border-radius: var(--r-window);
    border: 1px solid var(--border);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.5);
    cursor: zoom-in;
    max-width: 100%;
    height: auto;
    display: block;
    margin-bottom: var(--s-4);
  }

  /* HR */
  .ca__main :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: var(--s-7) 0;
    max-width: 72ch;
  }

  /* ── TOC ─────────────────────────────────────────────────────── */
  .ca__toc {
    display: none;
    width: 200px;
    flex-shrink: 0;
    overflow-y: auto;
    border-left: 1px solid var(--border);
    padding: var(--s-5) var(--s-4);
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }

  @media (min-width: 1024px) {
    .ca--has-toc .ca__toc {
      display: block;
    }
  }

  .toc-label {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin: 0 0 var(--s-3);
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .toc-item a {
    display: block;
    font-size: 0.8125rem;
    line-height: 1.4;
    color: var(--fg-muted);
    text-decoration: none;
    padding: 3px 8px;
    border-left: 2px solid transparent;
    transition:
      color 0.1s,
      border-color 0.1s;
  }

  .toc-item a:hover {
    color: var(--fg);
    border-left-color: var(--pai-blue);
  }

  .toc-h3 a {
    padding-left: 20px;
    font-size: 0.75rem;
  }

  /* ── Site footer (columnar, Tails-style) ─────────────────────── */
  .site-footer {
    margin-top: var(--s-7);
    padding: var(--s-6) 0 var(--s-4);
    border-top: 1px solid var(--border);
    max-width: none;
  }

  .sf-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: var(--s-5) var(--s-6);
    margin-bottom: var(--s-5);
  }

  .sf-col h4 {
    font-family: var(--font-pixel);
    color: var(--pai-yellow);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    margin: 0 0 var(--s-3);
    text-transform: none;
  }

  .sf-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: none;
  }

  .sf-col li {
    margin: 0 0 6px;
    line-height: 1.4;
  }

  .sf-col a {
    color: var(--fg-muted);
    text-decoration: none;
    font-size: 0.8125rem;
    transition: color 0.1s;
  }

  .sf-col a:hover {
    color: var(--pai-blue);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .sf-social {
    display: flex;
    gap: var(--s-3);
    margin-top: var(--s-3);
  }

  .sf-social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: var(--r-icon);
    background: var(--bg-elev);
    border: 1px solid var(--border);
    color: var(--fg-muted);
    transition:
      color 0.1s,
      border-color 0.1s,
      background 0.1s;
  }

  .sf-social a:hover {
    color: var(--pai-yellow);
    border-color: var(--pai-yellow);
    background: var(--bg);
  }

  .sf-bottom {
    padding-top: var(--s-4);
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: var(--s-3);
    flex-wrap: wrap;
  }

  .sf-brand {
    font-size: 0.75rem;
    color: var(--fg-muted);
    display: flex;
    align-items: center;
    gap: var(--s-2);
  }

  .sf-pai {
    font-family: var(--font-pixel);
    color: var(--pai-yellow);
    font-size: 0.875rem;
  }

  /* ── Footer CTAs ─────────────────────────────────────────────── */
  .ca__footer {
    display: flex;
    gap: var(--s-3);
    padding: var(--s-2) var(--s-5);
    border-top: 1px solid var(--border);
    background: var(--bg-elev);
    flex-shrink: 0;
    align-items: center;
  }

  .cta {
    padding: 6px var(--s-4);
    border-radius: var(--r-icon);
    border: 1px solid var(--border);
    background: transparent;
    color: var(--fg-muted);
    cursor: pointer;
    font-size: 0.875rem;
    font-family: var(--font-ui);
    transition:
      background 0.1s,
      color 0.1s;
    white-space: nowrap;
  }

  .cta:hover {
    background: var(--bg);
    color: var(--fg);
  }

  .cta--primary {
    background: var(--pai-blue);
    color: #0f0f1a;
    border-color: var(--pai-blue);
    font-weight: 600;
  }

  .cta--primary:hover {
    background: var(--pai-yellow);
    border-color: var(--pai-yellow);
    color: #0f0f1a;
  }

  /* ── Copy button ─────────────────────────────────────────────── */
  :global(.copy-wrap) {
    position: relative;
    max-width: 72ch;
    margin-bottom: var(--s-5);
  }

  :global(.copy-wrap pre) {
    margin-bottom: 0;
  }

  :global(.copy-btn) {
    position: absolute;
    top: var(--s-2);
    right: var(--s-2);
    padding: 2px 10px;
    border-radius: 4px;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--fg-muted);
    font-size: 0.75rem;
    cursor: pointer;
    font-family: var(--font-ui);
    opacity: 0;
    transition: opacity 0.15s;
    z-index: 1;
  }

  :global(.copy-wrap:hover .copy-btn) {
    opacity: 1;
  }

  /* ── Lightbox ────────────────────────────────────────────────── */
  :global(.lb-overlay) {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.88);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 100;
    cursor: zoom-out;
    animation: lb-in 0.15s ease;
  }

  :global(.lb-overlay img) {
    max-width: 90vw;
    max-height: 90vh;
    border-radius: var(--r-window);
    box-shadow: 0 8px 64px rgba(0, 0, 0, 0.8);
    cursor: default;
    border: 1px solid var(--border);
  }

  @keyframes lb-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
</style>

<script>
  import { bridge } from '../apps/_bridge.js'
  import { initSiteMenu } from '../shell/site-menu.ts'

  initSiteMenu()

  // ── Copy-to-clipboard on code blocks ──────────────────────────
  document.querySelectorAll<HTMLPreElement>('pre').forEach((pre) => {
    const wrap = document.createElement('div')
    wrap.className = 'copy-wrap'
    pre.parentNode!.insertBefore(wrap, pre)
    wrap.appendChild(pre)

    const btn = document.createElement('button')
    btn.className = 'copy-btn'
    btn.textContent = 'Copy'
    btn.addEventListener('click', () => {
      const text = pre.querySelector('code')?.textContent ?? pre.textContent ?? ''
      navigator.clipboard.writeText(text).then(() => {
        btn.textContent = '✓ Copied'
        setTimeout(() => {
          btn.textContent = 'Copy'
        }, 2000)
      })
    })
    wrap.appendChild(btn)
  })

  // ── Lightbox for content images ───────────────────────────────
  document.querySelectorAll<HTMLImageElement>('#ca-main img').forEach((img) => {
    img.addEventListener('click', () => {
      const overlay = document.createElement('div')
      overlay.className = 'lb-overlay'
      const clone = new Image()
      clone.src = img.src
      clone.alt = img.alt
      overlay.appendChild(clone)
      overlay.addEventListener('click', () => overlay.remove())
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') overlay.remove()
      }, { once: true })
      document.body.appendChild(overlay)
    })
  })

  // ── Open app in parent shell ──────────────────────────────────
  document.querySelectorAll<HTMLElement>('[data-open-app]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const appId = btn.dataset.openApp?.toLowerCase()
      if (!appId) return
      if (bridge.inShell) {
        bridge.openApp(appId)
      } else {
        window.location.href = `/apps/${appId}`
      }
    })
  })

  // ── TOC active heading tracking ───────────────────────────────
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-item a')
  if (tocLinks.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const id = entry.target.id
            tocLinks.forEach((a) => {
              const active = a.getAttribute('href') === `#${id}`
              a.style.color = active ? 'var(--pai-blue)' : ''
              a.style.borderLeftColor = active ? 'var(--pai-blue)' : ''
            })
            break
          }
        }
      },
      { rootMargin: '-10% 0% -80% 0%' }
    )
    document.querySelectorAll<HTMLElement>('#ca-main [id]').forEach((el) => observer.observe(el))
  }
</script>
