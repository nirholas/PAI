#!/bin/bash
set -euo pipefail

# ── Install CTRL Web Desktop ─────────────────────────────────────────
# Runs inside the chroot during ISO build.
# Downloads the CTRL web OS from GitHub and installs it as the
# primary desktop served via a local web server.
# CTRL is a full web-based desktop (HTML/CSS/JS) from:
#   https://github.com/nirholas/CTRL
# ──────────────────────────────────────────────────────────────────────

echo "[pai-web] Installing CTRL web desktop..."

CTRL_DIR="/opt/ctrl-desktop"
mkdir -p "$CTRL_DIR"

# ── 1. Download CTRL from GitHub (pinned commit)
# Pinned to a specific commit SHA so a compromise of the CTRL repo's main
# branch cannot silently flow into a PAI build. Bump this when intentionally
# uptaking a new CTRL release.
CTRL_COMMIT="27db3324644463b5ff34c08964edf011fcf5203b"
echo "[pai-web] Downloading CTRL from GitHub (commit ${CTRL_COMMIT})..."
CTRL_ARCHIVE="/tmp/ctrl-${CTRL_COMMIT}.tar.gz"
curl -fsSL "https://github.com/nirholas/CTRL/archive/${CTRL_COMMIT}.tar.gz" \
    -o "$CTRL_ARCHIVE"

# Verify download integrity
# SHA256 for this specific commit tarball (27db3324644463b5ff34c08964edf011fcf5203b):
echo "3e85d88711e8354cdaa2aadf29d5595de70be6a23ecdba986c2a72ed3150ff28  ${CTRL_ARCHIVE}" | sha256sum -c
echo "[pai-web] CTRL archive integrity verified"

# Extract into /opt/ctrl-desktop/
tar xzf "$CTRL_ARCHIVE" -C "$CTRL_DIR" --strip-components=1
rm -f "$CTRL_ARCHIVE"

echo "[pai-web] CTRL installed to $CTRL_DIR"
ls -la "$CTRL_DIR"

# ── 2. Create systemd service to serve CTRL on port 8080
cat > /etc/systemd/system/ctrl-desktop.service <<'EOF'
[Unit]
Description=CTRL Web Desktop (PAI Web Edition)
After=network.target

[Service]
Type=simple
User=user
WorkingDirectory=/opt/ctrl-desktop
ExecStart=/usr/bin/python3 -m http.server 8080 --bind 127.0.0.1
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
EOF

systemctl enable ctrl-desktop.service

echo "[pai-web] CTRL web desktop service enabled (port 8080)"

# ── 3. Create PAI Chat route inside CTRL
# Insert the PAI Chat UI as an "app" within CTRL's web desktop
CHAT_DIR="/opt/ctrl-desktop/apps/pai-chat"
mkdir -p "$CHAT_DIR"

cat > "$CHAT_DIR/index.html" <<'HTMLEOF'
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PAI Chat</title>
<style>
  :root {
    --bg: #0f0f1a; --surface: #1a1a2e; --border: #2a2a3e;
    --text: #e0e0e0; --accent: #7aa2f7; --dim: #888;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { background: var(--bg); color: var(--text); font-family: system-ui, sans-serif; height: 100vh; display: flex; flex-direction: column; }

  header { background: var(--surface); border-bottom: 1px solid var(--border); padding: 10px 16px; display: flex; align-items: center; gap: 10px; }
  header h1 { font-size: 16px; color: var(--accent); }
  #status { font-size: 12px; color: var(--dim); margin-left: auto; }

  #messages { flex: 1; overflow-y: auto; padding: 16px; }
  .msg { margin-bottom: 12px; max-width: 80%; }
  .msg.user { margin-left: auto; background: var(--accent); color: #0f0f1a; padding: 10px 14px; border-radius: 12px 12px 0 12px; }
  .msg.assistant { background: var(--surface); padding: 10px 14px; border-radius: 12px 12px 12px 0; border: 1px solid var(--border); }
  .msg pre { background: #0a0a15; padding: 8px; border-radius: 6px; overflow-x: auto; margin: 6px 0; font-size: 13px; }

  #input-bar { display: flex; padding: 12px; gap: 8px; background: var(--surface); border-top: 1px solid var(--border); }
  #prompt { flex: 1; padding: 10px 14px; background: var(--bg); border: 1px solid var(--border); border-radius: 8px; color: var(--text); font-size: 14px; resize: none; }
  #prompt:focus { outline: none; border-color: var(--accent); }
  #send { padding: 10px 20px; background: var(--accent); color: #0f0f1a; border: none; border-radius: 8px; font-weight: 600; cursor: pointer; }
  #send:hover { opacity: 0.9; }
</style>
</head>
<body>
<header>
  <h1>PAI Chat</h1>
  <span id="status">Connecting...</span>
</header>
<div id="messages"></div>
<div id="input-bar">
  <textarea id="prompt" rows="1" placeholder="Ask PAI anything..."></textarea>
  <button id="send">Send</button>
</div>
<script>
const OLLAMA = 'http://127.0.0.1:11434';
const MODEL = 'phi3:mini';
const msgs = document.getElementById('messages');
const prompt = document.getElementById('prompt');
const status = document.getElementById('status');
const history = [];

// Check Ollama
fetch(OLLAMA + '/api/version').then(r => r.json())
  .then(() => { status.textContent = 'Ollama ready'; status.style.color = '#4ade80'; })
  .catch(() => { status.textContent = 'Ollama offline'; status.style.color = '#f87171'; });

function addMsg(role, text) {
  const d = document.createElement('div');
  d.className = 'msg ' + role;
  d.textContent = text;
  msgs.appendChild(d);
  msgs.scrollTop = msgs.scrollHeight;
  return d;
}

async function send() {
  const text = prompt.value.trim();
  if (!text) return;
  prompt.value = '';
  addMsg('user', text);
  history.push({ role: 'user', content: text });

  const el = addMsg('assistant', '');
  let full = '';
  try {
    const res = await fetch(OLLAMA + '/api/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ model: MODEL, messages: history, stream: true })
    });
    const reader = res.body.getReader();
    const dec = new TextDecoder();
    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      for (const line of dec.decode(value).split('\n').filter(Boolean)) {
        try {
          const j = JSON.parse(line);
          if (j.message?.content) { full += j.message.content; el.textContent = full; }
        } catch {}
      }
    }
    history.push({ role: 'assistant', content: full });
  } catch (e) {
    el.textContent = 'Error: ' + e.message;
  }
  msgs.scrollTop = msgs.scrollHeight;
}

document.getElementById('send').addEventListener('click', send);
prompt.addEventListener('keydown', e => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(); } });
</script>
</body>
</html>
HTMLEOF

echo "[pai-web] PAI Chat app installed in CTRL desktop"
