FROM debian:bookworm-slim

# Force fresh apt state (avoids stale GPG signature errors in Docker layer cache)
RUN rm -rf /var/lib/apt/lists/* && \
    apt-get update && apt-get install -y --no-install-recommends \
    live-build \
    debootstrap \
    debian-archive-keyring \
    squashfs-tools \
    xorriso \
    grub-pc-bin \
    grub-efi-amd64-bin \
    mtools \
    dosfstools \
    ca-certificates \
    curl \
    python3 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /pai

# Copy build config into container
COPY . .

RUN chmod +x build.sh config/hooks/live/*.hook.chroot \
    config/includes.chroot_after_packages/usr/local/bin/pai-setup \
    config/includes.chroot_after_packages/usr/local/bin/pai-mac-spoof \
    config/includes.chroot_after_packages/usr/local/bin/pai-persistence \
    config/includes.chroot_after_packages/usr/local/bin/pai-privacy \
    config/includes.chroot_after_packages/usr/local/bin/pai-waybar-privacy \
    config/includes.chroot_after_packages/usr/local/bin/pai-waybar-crypto \
    config/includes.chroot_after_packages/usr/local/bin/pai-transcribe \
    config/includes.chroot_after_packages/usr/local/bin/pai-ssh-setup \
    config/includes.chroot_after_packages/usr/local/bin/pai-models \
    config/includes.chroot_after_packages/usr/local/bin/pai-shutdown \
    config/includes.chroot_after_packages/usr/local/bin/pai-memory-wipe \
    config/includes.chroot_after_packages/usr/local/bin/pai-waybar-ollama \
    config/includes.chroot_after_packages/usr/local/bin/pai-profile-init \
    config/includes.chroot_after_packages/usr/local/bin/pai-welcome \
    config/includes.chroot_after_packages/usr/local/bin/pai-settings \
    config/includes.chroot_after_packages/usr/local/bin/pai-save \
    scripts/flash-usb.sh

# Must run with: docker run --privileged
CMD ["bash", "build.sh"]
