# PAI — Open WebUI environment
# Edit and `systemctl restart open-webui` to apply.
# Reference: https://docs.openwebui.com/getting-started/env-configuration/

# ── Branding ─────────────────────────────────────────────────────────
WEBUI_NAME=PAI
WEBUI_URL=http://localhost:8080
WEBUI_FAVICON_URL=/static/favicon.png
WEBUI_LOGO_URL=/static/pai-logo.png

# ── Runtime ──────────────────────────────────────────────────────────
HOME=/var/lib/open-webui
DATA_DIR=/var/lib/open-webui
HOST=0.0.0.0
PORT=8080

# ── Backend ──────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
ENABLE_OLLAMA_API=true
ENABLE_OPENAI_API=false

# ── Auth (single-user live system) ───────────────────────────────────
WEBUI_AUTH=False
ENABLE_SIGNUP=false
SHOW_ADMIN_DETAILS=false
DEFAULT_USER_ROLE=user

# ── Offline / privacy ────────────────────────────────────────────────
OFFLINE_MODE=true
ANONYMIZED_TELEMETRY=false
DO_NOT_TRACK=true
SCARF_NO_ANALYTICS=true
ENABLE_COMMUNITY_SHARING=false
ENABLE_MESSAGE_RATING=false
