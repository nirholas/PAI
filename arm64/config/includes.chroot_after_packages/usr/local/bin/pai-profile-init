#!/bin/bash
# PAI Profile Init — runs at boot, activates the selected profile
# Reads pai.profile=X from kernel cmdline, configures services + desktop

PROFILE=$(grep -oP 'pai\.profile=\K\S+' /proc/cmdline 2>/dev/null || echo "full")

# Persist for other scripts to read
echo "$PROFILE" > /run/pai-profile
chmod 644 /run/pai-profile

log() { echo "[pai-profile] $*" | tee -a /var/log/pai-profile.log; }

log "Activating profile: $PROFILE"

# ── Service sets per profile ──────────────────────────────────────────
# All profiles always get: ollama, open-webui, NetworkManager
# Optional services started per profile:

start_services() {
    for svc in "$@"; do
        systemctl start "$svc" 2>/dev/null && log "  started: $svc" || log "  skip: $svc"
    done
}

stop_services() {
    for svc in "$@"; do
        systemctl stop "$svc" 2>/dev/null || true
    done
}

case "$PROFILE" in

  ai)
    log "Profile: AI Only — Ollama + Open WebUI"
    # Tor stays off, dev/crypto services not started
    stop_services tor
    ;;

  dev)
    log "Profile: Developer — AI + dev toolchain"
    stop_services tor
    # Dev tools are just binaries — no extra services needed
    ;;

  crypto)
    log "Profile: Crypto — AI + wallets + privacy"
    start_services tor
    ;;

  privacy)
    log "Profile: Privacy Mode — AI + full Tor routing"
    start_services tor
    # Route all traffic through Tor
    if command -v pai-privacy &>/dev/null; then
        pai-privacy on 2>/dev/null || true
        log "  Tor routing enabled"
    fi
    ;;

  full|*)
    log "Profile: Full — everything"
    start_services tor
    PROFILE=full
    echo "full" > /run/pai-profile
    ;;

esac

# ── Write profile env for Sway/apps to source ────────────────────────
cat > /run/pai-profile-env <<EOF
PAI_PROFILE=$PROFILE
PAI_HAS_DEV=$([ "$PROFILE" = "dev" ] || [ "$PROFILE" = "full" ] && echo 1 || echo 0)
PAI_HAS_CRYPTO=$([ "$PROFILE" = "crypto" ] || [ "$PROFILE" = "full" ] && echo 1 || echo 0)
PAI_HAS_TOR=$([ "$PROFILE" = "crypto" ] || [ "$PROFILE" = "privacy" ] || [ "$PROFILE" = "full" ] && echo 1 || echo 0)
EOF
chmod 644 /run/pai-profile-env

# ── Generate profile-specific Sway include ────────────────────────────
SWAY_PROFILE_DIR="/etc/sway/profile.d"
mkdir -p "$SWAY_PROFILE_DIR"

# Start with a clean profile fragment
cat > "$SWAY_PROFILE_DIR/active.conf" <<SWAYEOF
# Auto-generated by pai-profile-init — do not edit

# Profile: $PROFILE
set \$pai_profile $PROFILE
SWAYEOF

# Append profile-specific keybindings/autostart
if [ -f "$SWAY_PROFILE_DIR/${PROFILE}.conf" ]; then
    cat "$SWAY_PROFILE_DIR/${PROFILE}.conf" >> "$SWAY_PROFILE_DIR/active.conf"
fi

log "Profile $PROFILE activated. Sway config written."
